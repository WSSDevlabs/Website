---
import { SITE } from '../../data/site';

const message = encodeURIComponent("Hi WSS DevLabs, I'd like to talk about a project.");
const href = SITE.whatsapp ? `https://wa.me/${SITE.whatsapp}?text=${message}` : null;
---

{
  href && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat with us on WhatsApp"
      class="fixed bottom-6 right-6 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-accent text-white shadow-lg shadow-accent/20 transition-transform duration-200 ease-out hover:scale-105 max-md:bottom-20"
    >
      <svg viewBox="0 0 32 32" class="h-7 w-7" fill="currentColor" aria-hidden="true">
        <path d="M16.001 3C9.373 3 4 8.373 4 15c0 2.396.698 4.63 1.903 6.51L4 29l7.676-1.864A11.93 11.93 0 0 0 16 27c6.627 0 12-5.373 12-12S22.628 3 16.001 3Zm0 21.818a9.78 9.78 0 0 1-4.99-1.37l-.358-.213-4.553 1.106 1.218-4.435-.234-.372A9.78 9.78 0 0 1 5.182 15c0-5.964 4.854-10.818 10.819-10.818S26.818 9.036 26.818 15 21.965 24.818 16.001 24.818Zm5.61-7.97c-.307-.154-1.817-.897-2.099-.999-.282-.103-.487-.154-.692.153-.205.308-.794.999-.974 1.205-.179.205-.358.231-.665.077-.307-.154-1.296-.477-2.469-1.523-.913-.814-1.529-1.82-1.708-2.127-.179-.307-.019-.473.135-.626.139-.138.307-.358.461-.538.154-.179.205-.307.307-.512.103-.205.051-.384-.026-.538-.077-.154-.692-1.667-.949-2.283-.25-.6-.503-.519-.692-.529-.179-.009-.384-.011-.589-.011-.205 0-.538.077-.82.384-.282.307-1.077 1.052-1.077 2.565s1.102 2.974 1.256 3.18c.154.205 2.17 3.314 5.258 4.647.735.317 1.308.507 1.755.649.737.234 1.408.201 1.938.122.591-.088 1.817-.743 2.073-1.461.256-.717.256-1.333.179-1.461-.077-.128-.282-.205-.589-.358Z" />
      </svg>
    </a>
  )
}
