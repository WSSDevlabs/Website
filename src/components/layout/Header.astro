---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { NAV_GROUPS, NAV_LINKS, PRIMARY_CTA } from '../../data/nav';
import { SITE } from '../../data/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!-- Topbar: dark ink frame, mirrored by the footer -->
<div class="relative bg-ink">
  <Container class="flex h-9 items-center justify-between gap-4">
    <!-- Left: contact info -->
    <div class="flex items-center gap-5 text-[11px] text-white/55">
      {SITE.phone && (
        <a href={`tel:${SITE.phone}`} class="flex items-center gap-1.5 transition-colors hover:text-white">
          <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          {SITE.phone}
        </a>
      )}
      {SITE.email && (
        <a href={`mailto:${SITE.email}`} class="hidden items-center gap-1.5 transition-colors hover:text-white sm:flex">
          <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          {SITE.email}
        </a>
      )}
      {SITE.address && (
        <span class="hidden items-center gap-1.5 lg:flex">
          <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          {SITE.address}
        </span>
      )}
    </div>

    <!-- Right: social icon circles -->
    <div class="flex items-center gap-1.5">
      {SITE.social.facebook && (
        <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
           class="flex h-6 w-6 items-center justify-center rounded-full border border-white/15 text-white/55 transition-all hover:border-accent hover:bg-accent hover:text-white">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      )}
      {SITE.social.twitter && (
        <a href={SITE.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter"
           class="flex h-6 w-6 items-center justify-center rounded-full border border-white/15 text-white/55 transition-all hover:border-accent hover:bg-accent hover:text-white">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      )}
      {SITE.social.linkedin && (
        <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
           class="flex h-6 w-6 items-center justify-center rounded-full border border-white/15 text-white/55 transition-all hover:border-accent hover:bg-accent hover:text-white">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      )}
      {SITE.social.instagram && (
        <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
           class="flex h-6 w-6 items-center justify-center rounded-full border border-white/15 text-white/55 transition-all hover:border-accent hover:bg-accent hover:text-white">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      )}
      {SITE.social.github && (
        <a href={SITE.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub"
           class="flex h-6 w-6 items-center justify-center rounded-full border border-white/15 text-white/55 transition-all hover:border-accent hover:bg-accent hover:text-white">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      )}
    </div>
  </Container>
  <!-- Brand signature line: the four studio colors, used once per page -->
  <div
    class="h-[2px] w-full opacity-90"
    style="background: linear-gradient(90deg, var(--color-accent-red), var(--color-accent) 38%, var(--color-accent-yellow) 72%, var(--color-accent-green));"
    aria-hidden="true"
  >
  </div>
</div>

<header class="sticky top-3 z-50 px-3 sm:px-4">
  <div
    class="mx-auto flex h-14 max-w-5xl items-center justify-between rounded-full border border-line/80 bg-paper/85 pl-5 pr-2 shadow-[0_8px_32px_-12px_rgb(12_18_32/0.18)] backdrop-blur-xl"
  >
    <a href="/" class="flex items-center gap-2.5">
      <span class="flex items-center gap-[3px]" aria-hidden="true">
        <span class="h-5 w-2.5 rounded-[3px] bg-accent-red"></span>
        <span class="h-5 w-2.5 rounded-[3px] bg-accent"></span>
      </span>
      <span class="text-base font-bold tracking-tight text-ink">{SITE.name}</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-0.5 md:flex">
      {
        NAV_GROUPS.map((group) => {
          const groupActive = group.links.some((link) => isActive(link.href));
          return (
            <details class="nav-dropdown group relative">
              <summary
                class:list={[
                  'flex cursor-pointer list-none items-center gap-1 rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors duration-200 ease-out [&::-webkit-details-marker]:hidden',
                  groupActive ? 'bg-accent/10 text-accent' : 'text-ink-dim hover:bg-paper-dim hover:text-ink'
                ]}
              >
                {group.label}
                <svg class="h-3.5 w-3.5 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="absolute left-0 top-full z-10 mt-2 min-w-[180px] rounded-2xl border border-line/80 bg-paper/95 p-1.5 shadow-[0_16px_48px_-16px_rgb(12_18_32/0.25)] backdrop-blur-xl">
                {group.links.map((link) => (
                  <a
                    href={link.href}
                    class:list={[
                      'block rounded-xl px-3.5 py-2 text-sm font-medium transition-colors',
                      isActive(link.href) ? 'bg-accent/10 text-accent' : 'text-ink-dim hover:bg-paper-dim hover:text-ink'
                    ]}
                    aria-current={isActive(link.href) ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </details>
          );
        })
      }
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors duration-200 ease-out',
              isActive(link.href)
                ? 'bg-accent/10 text-accent'
                : 'text-ink-dim hover:bg-paper-dim hover:text-ink'
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <Button href={PRIMARY_CTA.href} variant="primary">{PRIMARY_CTA.label}</Button>
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Toggle navigation menu"
    >
      <svg
        id="nav-icon-open"
        class="h-6 w-6 text-ink"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"
        ></path>
      </svg>
      <svg
        id="nav-icon-close"
        class="hidden h-6 w-6 text-ink"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-nav"
    aria-label="Mobile"
    class="mx-auto mt-2 hidden max-w-5xl rounded-3xl border border-line/80 bg-paper/95 shadow-[0_16px_48px_-16px_rgb(12_18_32/0.25)] backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-1 p-4">
      {
        NAV_GROUPS.map((group, i) => (
          <div class:list={[i > 0 && 'mt-3 border-t border-line pt-3']}>
            <p class="mono-label px-3 pb-1 text-ink-dim/70">{group.label}</p>
            {group.links.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'block rounded-xl px-3 py-3 text-base font-medium',
                  isActive(link.href) ? 'bg-accent/10 text-accent' : 'text-ink'
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
      <div class="mt-3 border-t border-line pt-3">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class:list={[
                'block rounded-xl px-3 py-3 text-base font-medium',
                isActive(link.href) ? 'bg-accent/10 text-accent' : 'text-ink'
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <Button href={PRIMARY_CTA.href} variant="primary" class="mt-2">{PRIMARY_CTA.label}</Button>
    </div>
  </nav>
</header>

<script>
  function initNavToggle() {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-nav');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    if (!toggle || toggle.dataset.bound) return;
    toggle.dataset.bound = '1';

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu?.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    });
  }

  initNavToggle();
  document.addEventListener('astro:page-load', initNavToggle);

  function initNavDropdowns() {
    const dropdowns = document.querySelectorAll<HTMLDetailsElement>('.nav-dropdown');
    dropdowns.forEach((d) => {
      if (d.dataset.bound) return;
      d.dataset.bound = '1';
      d.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => d.removeAttribute('open'));
      });
    });

    if (!document.documentElement.dataset.navDropdownOutsideBound) {
      document.documentElement.dataset.navDropdownOutsideBound = '1';
      document.addEventListener('click', (e) => {
        document.querySelectorAll<HTMLDetailsElement>('.nav-dropdown[open]').forEach((d) => {
          if (!d.contains(e.target as Node)) d.removeAttribute('open');
        });
      });
    }
  }

  initNavDropdowns();
  document.addEventListener('astro:page-load', initNavDropdowns);
</script>
