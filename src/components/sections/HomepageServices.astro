---
import Container from '../ui/Container.astro';

const services = [
  {
    slug: 'ai-development',
    title: 'AI Development',
    description:
      'LLM-powered features, RAG pipelines, and workflow automation that help your product work smarter and your team move faster.',
    img: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1000&h=760&q=80',
    tone: 'red'
  },
  {
    slug: 'web-development',
    title: 'Web Development',
    description:
      'Custom-built, fast, typed websites. Engineered for speed and search visibility from the first commit.',
    img: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=700&h=440&q=80',
    tone: 'blue'
  },
  {
    slug: 'digital-marketing',
    title: 'Digital Marketing',
    description:
      'SEO, paid ads, social media strategy, and content marketing that bring the right people to your business.',
    img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=700&h=440&q=80',
    tone: 'green'
  }
];

const [featured, ...rest] = services;
---

<section class="py-14 md:py-20">
  <Container>
    <div class="panel overflow-hidden px-6 py-10 md:px-14 md:py-12">
      <!-- Section header -->
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <h2 class="h-section max-w-md" data-split>Boost your brand with our expertise</h2>
        <a
          href="/services"
          class="link-underline shrink-0 pb-1 text-sm font-semibold text-ink"
        >
          View all services
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Asymmetric bento: featured large left, two stacked right -->
      <div class="mt-10 grid gap-5 lg:grid-cols-5" data-stagger>
        <!-- Featured card -->
        <a
          href={`/services/${featured.slug}`}
          data-stagger-child
          class="card card-lift spotlight-card group relative flex min-h-[26rem] flex-col justify-end overflow-hidden !rounded-3xl !border-0 lg:col-span-3"
        >
          <img
            src={featured.img}
            alt=""
            class="absolute inset-0 h-full w-full scale-105 object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-110"
            loading="lazy"
            width="1000"
            height="760"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent" aria-hidden="true"></div>
          <div class="relative p-8">
            <p class="mono-label text-white/70">Featured service</p>
            <h3 class="mt-2 text-2xl font-semibold tracking-tight text-white md:text-3xl">
              {featured.title}
            </h3>
            <p class="mt-2 max-w-md text-sm leading-relaxed text-white/75">{featured.description}</p>
            <p class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-white">
              Learn more
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </p>
          </div>
        </a>

        <!-- Two stacked cards -->
        <div class="grid gap-5 lg:col-span-2">
          {
            rest.map((svc) => (
              <a
                href={`/services/${svc.slug}`}
                data-stagger-child
                class="card card-lift spotlight-card group flex flex-col overflow-hidden !rounded-3xl p-0"
              >
                <div class="h-36 overflow-hidden">
                  <img
                    src={svc.img}
                    alt=""
                    class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                    loading="lazy"
                    width="700"
                    height="440"
                  />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                    {svc.title}
                  </h3>
                  <p class="mt-1.5 flex-1 text-sm leading-relaxed text-ink-dim">{svc.description}</p>
                  <p class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
                    Learn more
                    <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                    </svg>
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
