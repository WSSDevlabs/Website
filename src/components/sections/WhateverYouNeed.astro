---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

const clusters = [
  {
    title: 'Build It',
    items: [
      'Want a website? We build it.',
      'Want a mobile app? We build it.',
      'Need your own custom system? We build it.',
      "Working on a final year project? We build it with you.",
    ],
  },
  {
    title: 'Grow It',
    items: [
      'Want to run marketing or ads? We manage it.',
      'Need someone to handle your social posts? We run it.',
      'Need product photography and placement? We shoot it.',
      'Need something designed or rebranded? We design it.',
    ],
  },
  {
    title: 'Launch It',
    items: [
      'Applying for a government grant project? We deliver it.',
      'Opening a small business from scratch? We help launch it.',
      "Not sure which of these you need? We'll help you figure it out.",
    ],
  },
];
---

<Section rule>
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="h-section" data-split>Whatever it is, we probably build it</h2>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-3" data-stagger>
      {
        clusters.map((cluster) => (
          <div data-stagger-child class="card p-7">
            <h3 class="font-semibold tracking-tight text-ink">{cluster.title}</h3>
            <ul class="mt-4 space-y-3">
              {cluster.items.map((item) => (
                <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink-dim">
                  <svg class="mt-[3px] h-3.5 w-3.5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
