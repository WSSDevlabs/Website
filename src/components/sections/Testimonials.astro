---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

type Testimonial = { quote: string; author: string; role: string; company?: string; rating?: number };

type Props = {
  testimonials?: Testimonial[];
};

const { testimonials = [] } = Astro.props;

const markColors = ['text-accent', 'text-accent-blue', 'text-accent-green', 'text-accent-yellow'];
---

{
  testimonials.length > 0 && (
    <Section rule>
      <Container>
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="h-section" data-split>What clients say</h2>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {
            testimonials.map((t, i) => (
              <div data-stagger-child class="flex flex-col rounded-3xl bg-paper-dim p-7">
                <div class="flex items-center justify-between gap-3">
                  <img
                    src={`https://picsum.photos/seed/${t.author}/80/80`}
                    alt={t.author}
                    class="h-11 w-11 shrink-0 rounded-full object-cover"
                    loading="lazy"
                    width="80"
                    height="80"
                  />
                  {t.company && (
                    <span class="inline-flex min-w-0 items-center gap-1.5 rounded-full border border-line bg-paper px-3 py-1.5 text-xs font-semibold text-ink">
                      <svg class:list={['h-3.5 w-3.5 shrink-0', markColors[i % markColors.length]]} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="m12 2 2.6 5.6L21 8.5l-4.6 4.2L17.6 19 12 15.9 6.4 19l1.2-6.3L3 8.5l6.4-.9Z" />
                      </svg>
                      <span class="truncate">{t.company}</span>
                    </span>
                  )}
                </div>

                <p class="mt-6 text-3xl font-black leading-none text-accent" aria-hidden="true">&ldquo;</p>

                <p class="mt-4 flex-1 text-lg font-semibold leading-snug tracking-tight text-ink">{t.quote}</p>

                <div class="mt-7 border-l-2 border-line pl-3.5">
                  <p class="font-semibold text-ink">{t.author}</p>
                  <p class="mt-0.5 text-sm text-ink-dim">{t.role}{t.company && `, ${t.company}`}</p>
                </div>
              </div>
            ))
          }
        </div>
      </Container>
    </Section>
  )
}
