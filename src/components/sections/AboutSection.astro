---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

const capabilities = [
  {
    label: 'Web & Mobile Development',
    detail: 'Typed, custom-coded builds. No template lock-in.'
  },
  {
    label: 'AI & Custom Systems',
    detail: 'LLM features, internal tools, CMS and ERP.'
  },
  {
    label: 'Marketing & Business Growth',
    detail: 'SEO, paid ads, and analytics that feed decisions.'
  }
];
---

<Section>
  <Container>
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Left: two stacked images with parallax -->
      <div class="flex gap-5">
        <div class="h-80 flex-1 overflow-hidden rounded-3xl border border-line shadow-card sm:h-[430px]">
          <img
            src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=480&h=720&q=80"
            alt="WSS DevLabs team"
            class="h-full w-full scale-110 object-cover"
            loading="lazy"
            width="480"
            height="720"
            data-parallax="8"
          />
        </div>
        <div class="h-80 flex-1 overflow-hidden rounded-3xl border border-line shadow-card sm:h-[430px]">
          <img
            src="https://images.unsplash.com/photo-1517180102446-f3ece451e9d8?auto=format&fit=crop&w=480&h=640&q=80"
            alt="Our workspace"
            class="h-full w-full scale-110 object-cover"
            loading="lazy"
            width="480"
            height="640"
            data-parallax="13"
          />
        </div>
      </div>

      <!-- Right: content -->
      <div class="flex flex-col justify-center">
        <Eyebrow label="About Us" />
        <h2 class="h-section mt-5" data-split>Building software that works for your business</h2>
        <p class="mt-5 leading-relaxed text-ink-dim" data-color-reveal>
          WSS DevLabs is a Malaysian digital studio that builds websites, mobile apps, custom
          business systems, and AI-powered software. We work directly with startups and SMEs, so
          every project is <span data-accent>custom-built, typed, and performance-led</span> from
          the first commit.
        </p>

        <!-- Capability rows -->
        <div class="mt-9 space-y-0">
          {
            capabilities.map((cap, i) => (
              <div class:list={['group flex items-start gap-4 py-4', i > 0 && 'border-t border-line']}>
                <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/8 transition-colors duration-300 group-hover:bg-accent group-hover:text-white">
                  <svg class="h-4 w-4 text-accent transition-colors duration-300 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <div>
                  <p class="font-semibold text-ink">{cap.label}</p>
                  <p class="mt-0.5 text-sm text-ink-dim">{cap.detail}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</Section>
