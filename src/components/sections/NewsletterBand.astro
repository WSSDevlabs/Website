---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
---

<Section rule class="bg-paper-dim">
  <Container class="max-w-2xl text-center">
    <p class="mono-label text-accent">Newsletter</p>
    <h2 class="h-section mt-4" data-split>Subscribe for digital growth tips &amp; updates</h2>
    <p class="mx-auto mt-4 max-w-md text-ink-dim">
      Practical insights on web, AI, and marketing, delivered monthly. No spam, unsubscribe any
      time.
    </p>

    <form
      class="mx-auto mt-9 flex max-w-md items-center gap-1.5 rounded-full border border-line bg-paper p-1.5 shadow-card transition-shadow focus-within:shadow-card-hover"
      onsubmit="return false;"
      aria-label="Newsletter signup"
    >
      <label for="nl-email" class="sr-only">Email address</label>
      <input
        id="nl-email"
        type="email"
        placeholder="Enter email address"
        class="min-w-0 flex-1 bg-transparent px-4 text-sm text-ink placeholder:text-muted focus:outline-none"
      />
      <button
        type="submit"
        class="shrink-0 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-dim"
      >
        Subscribe
      </button>
    </form>
  </Container>
</Section>
