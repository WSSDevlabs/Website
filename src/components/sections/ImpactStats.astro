---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

type Stat = { value: string; label: string };

type Props = {
  stats?: Stat[];
};

const defaultStats: Stat[] = [
  { value: '50+', label: 'Projects delivered' },
  { value: '100%', label: 'Client satisfaction' },
  { value: '10', label: 'Service areas' },
  { value: '3+', label: 'Years in business' }
];

const { stats = defaultStats } = Astro.props;

const parsed = stats.map((stat) => {
  const match = stat.value.match(/^(\d+)(.*)$/);
  return {
    num: match ? match[1] : '0',
    suffix: match ? match[2] : '',
    label: stat.label
  };
});
---

<Section rule>
  <Container>
    <div class="grid grid-cols-2 gap-y-12 lg:grid-cols-4">
      {
        parsed.map((stat, i) => (
          <div
            class:list={[
              'flex flex-col items-start px-2 sm:px-8',
              i > 0 && 'lg:border-l lg:border-line',
              i % 2 === 1 && 'border-l border-line lg:border-line'
            ]}
          >
            <p class="num-feature text-6xl text-ink md:text-7xl" data-count={stat.num} data-count-suffix={stat.suffix}>
              {stat.num}{stat.suffix}
            </p>
            <p class="mono-label mt-4 text-ink-dim">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
