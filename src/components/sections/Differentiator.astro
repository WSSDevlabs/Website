---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

const features = [
  {
    title: 'Real Engineering',
    description:
      'Custom-coded, typed, and version-controlled from day one. Not a page-builder stack that limits growth.',
    icon: 'M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5'
  },
  {
    title: 'Not Templated',
    description:
      'Every build is shaped around your goals. No hidden theme constraints, no decisions you never agreed to.',
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42'
  },
  {
    title: 'Direct with the Builder',
    description: 'You work with the engineer on your project, not a relay chain of account managers.',
    icon: 'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z'
  },
  {
    title: 'Performance-Obsessed',
    description:
      'Speed is a feature, not a setting. We set a performance budget at the start and enforce it at every layer.',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z'
  }
];
---

<Section rule>
  <Container>
    <div class="grid gap-14 lg:grid-cols-2 lg:items-center lg:gap-20">
      <!-- Left: large image + overlapping stat card -->
      <div class="relative hidden lg:block">
        <div class="overflow-hidden rounded-3xl border border-line shadow-card">
          <img
            src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=800&h=960&q=80"
            alt="WSS DevLabs team at work"
            class="h-[500px] w-full scale-110 object-cover"
            loading="lazy"
            width="800"
            height="960"
            data-parallax="9"
          />
        </div>

        <!-- Overlapping stat card -->
        <div class="absolute -bottom-7 -right-5 rounded-2xl border border-line bg-paper px-6 py-5 shadow-float">
          <p class="stat-num text-4xl text-ink" data-count="50" data-count-suffix="+">50+</p>
          <p class="mono-label mt-1.5 text-ink-dim">Happy clients</p>
        </div>
      </div>

      <!-- Right: content -->
      <div>
        <h2 class="h-section" data-split>Why businesses trust WSS DevLabs</h2>
        <p class="mt-5 max-w-lg leading-relaxed text-ink-dim">
          We are a lean Malaysian studio that punches above its weight. No outsourcing, no juniors
          left unsupervised, no upsells for things you don't need.
        </p>

        <!-- 2x2 feature rows, no card boxes -->
        <div class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2" data-stagger>
          {
            features.map((feat) => (
              <div data-stagger-child class="group">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/8 transition-all duration-300 group-hover:scale-105 group-hover:bg-accent">
                  <svg class="h-[18px] w-[18px] text-accent transition-colors duration-300 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                    <path stroke-linecap="round" stroke-linejoin="round" d={feat.icon} />
                  </svg>
                </span>
                <p class="mt-4 font-semibold tracking-tight text-ink">{feat.title}</p>
                <p class="mt-1.5 text-sm leading-relaxed text-ink-dim">{feat.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</Section>
