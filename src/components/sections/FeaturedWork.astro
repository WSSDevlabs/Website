---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

type Props = {
  projects: CollectionEntry<'projects'>[];
};

const { projects } = Astro.props;

const placeholders = [
  {
    id: 'ph-1',
    title: 'E-Commerce Platform',
    category: 'Web Development',
    headlineResult: 'Custom storefront with 40% faster checkout flow.',
    img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=900&h=680&q=80'
  },
  {
    id: 'ph-2',
    title: 'Business Analytics Dashboard',
    category: 'Custom Systems',
    headlineResult: 'Real-time KPI visibility across 6 departments.',
    img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=900&h=680&q=80'
  },
  {
    id: 'ph-3',
    title: 'Brand Identity & Website',
    category: 'Branding',
    headlineResult: 'Full rebrand with 2x increase in qualified leads.',
    img: 'https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&w=900&h=680&q=80'
  },
  {
    id: 'ph-4',
    title: 'AI Lead Qualification Bot',
    category: 'AI Development',
    headlineResult: '70% reduction in sales response time.',
    img: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=900&h=680&q=80'
  }
];

const categoryText: Record<string, string> = {
  'Web Development': 'text-accent',
  'Custom Systems': 'text-accent-yellow',
  Branding: 'text-accent-green',
  'AI Development': 'text-accent-red'
};

const hasProjects = projects.length > 0;
const items = hasProjects
  ? projects.slice(0, 4).map((p) => ({
      href: `/work/${p.id}`,
      title: p.data.title,
      category: p.data.category,
      result: p.data.headlineResult,
      image: p.data.heroImage
    }))
  : placeholders.map((ph) => ({
      href: '/work',
      title: ph.title,
      category: ph.category,
      result: ph.headlineResult,
      image: ph.img
    }));
---

<Section rule class="bg-paper-dim">
  <Container>
    <div class="flex items-end justify-between">
      <h2 class="h-section" data-split>Projects we're proud of</h2>
      <a href="/work" class="link-underline hidden shrink-0 pb-1 text-sm font-semibold text-ink sm:inline-flex">
        View all work
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Editorial project index: staggered columns, caption below image -->
    <div class="mt-12 grid gap-x-8 gap-y-14 sm:grid-cols-2" data-stagger>
      {
        items.map((item, i) => (
          <a
            href={item.href}
            data-stagger-child
            class:list={['group block', i % 2 === 1 && 'sm:mt-16']}
          >
            <div class="relative overflow-hidden rounded-3xl border border-line bg-paper shadow-card transition-shadow duration-500 group-hover:shadow-card-hover">
              <div class:list={['overflow-hidden', i % 2 === 1 ? 'aspect-[5/4]' : 'aspect-[4/3]']}>
                {hasProjects ? (
                  <Image
                    src={item.image as ImageMetadata}
                    alt={item.title}
                    class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                    width={900}
                    height={680}
                  />
                ) : (
                  <img
                    src={item.image as string}
                    alt={item.title}
                    class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                    loading="lazy"
                    width="900"
                    height="680"
                  />
                )}
              </div>
              <span class="absolute bottom-4 right-4 flex h-10 w-10 translate-y-2 items-center justify-center rounded-full bg-paper/90 opacity-0 shadow-float backdrop-blur-sm transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <svg class="h-4 w-4 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5 19.5 4.5m0 0h-10m10 0v10" />
                </svg>
              </span>
            </div>
            <div class="mt-5 flex items-start justify-between gap-6">
              <div>
                <p class:list={['mono-label', categoryText[item.category] ?? 'text-accent']}>
                  {item.category}
                </p>
                <h3 class="mt-2 text-xl font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                  {item.title}
                </h3>
                <p class="mt-1 text-sm text-ink-dim">{item.result}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <a
      href="/work"
      class="link-underline mt-12 inline-flex pb-1 text-sm font-semibold text-ink sm:hidden"
    >
      View all work
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </Container>
</Section>
