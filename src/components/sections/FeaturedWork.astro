---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

type Props = {
  projects: CollectionEntry<'projects'>[];
};

const { projects } = Astro.props;

const placeholders = [
  {
    id: 'ph-1',
    title: 'E-Commerce Platform',
    category: 'Web Development',
    headlineResult: 'Custom storefront with 40% faster checkout flow.',
    tag: 'Full Rebuild',
    img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=900&h=1200&q=80'
  },
  {
    id: 'ph-2',
    title: 'Business Analytics Dashboard',
    category: 'Custom Systems',
    headlineResult: 'Real-time KPI visibility across 6 departments.',
    tag: 'Real-Time Data',
    img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=900&h=1200&q=80'
  },
  {
    id: 'ph-3',
    title: 'Brand Identity & Website',
    category: 'Branding',
    headlineResult: 'Full rebrand with 2x increase in qualified leads.',
    tag: 'Brand + Web',
    img: 'https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&w=900&h=1200&q=80'
  },
  {
    id: 'ph-4',
    title: 'AI Lead Qualification Bot',
    category: 'AI Development',
    headlineResult: '70% reduction in sales response time.',
    tag: 'LLM-Powered',
    img: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=900&h=1200&q=80'
  }
];

const hasProjects = projects.length > 0;
const items = hasProjects
  ? projects.slice(0, 4).map((p) => ({
      href: `/work/${p.id}`,
      title: p.data.title,
      category: p.data.category,
      result: p.data.headlineResult,
      tag: p.data.techStack?.[0] ?? p.data.services?.[0] ?? p.data.industry,
      image: p.data.heroImage
    }))
  : placeholders.map((ph) => ({
      href: '/work',
      title: ph.title,
      category: ph.category,
      result: ph.headlineResult,
      tag: ph.tag,
      image: ph.img
    }));

---

<Section rule class="bg-paper-dim">
  <Container>
    <div class="flex items-end justify-between">
      <h2 class="h-section" data-split>Projects we're proud of</h2>
      <a href="/work" class="link-underline hidden shrink-0 pb-1 text-sm font-semibold text-ink sm:inline-flex">
        View all work
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Stacked photo cards: portrait image, scrim overlay, hanging CTA pill -->
    <div class="mt-14 grid grid-cols-1 gap-x-6 gap-y-16 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
      {
        items.map((item) => (
          <a href={item.href} data-stagger-child class="group block">
            <div
              class="relative aspect-[3/4] overflow-hidden rounded-[2rem] shadow-card transition-all duration-500 [transition-timing-function:var(--ease-out-expo)] group-hover:-translate-y-2 group-hover:shadow-2xl group-hover:shadow-ink/25"
            >
              {hasProjects ? (
                <Image
                  src={item.image as ImageMetadata}
                  alt={item.title}
                  class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                  width={900}
                  height={1200}
                />
              ) : (
                <img
                  src={item.image as string}
                  alt={item.title}
                  class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                  loading="lazy"
                  width="900"
                  height="1200"
                />
              )}

              <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/25 to-transparent" aria-hidden="true" />

              <div class="absolute inset-x-0 bottom-0 p-5">
                <p class="mono-label text-white/70">{item.category}</p>
                <h3 class="mt-1.5 text-lg font-semibold leading-snug text-white">{item.title}</h3>
                <p class="mt-1.5 line-clamp-2 text-xs leading-relaxed text-white/70">{item.result}</p>

                <div class="mt-4 flex flex-wrap gap-1.5">
                  <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1 text-[10px] font-medium text-white/90 backdrop-blur-sm">
                    {item.category}
                  </span>
                  {item.tag && (
                    <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1 text-[10px] font-medium text-white/90 backdrop-blur-sm">
                      {item.tag}
                    </span>
                  )}
                </div>
              </div>
            </div>

            <!-- CTA pill hanging over the card's bottom edge -->
            <div class="relative z-10 mx-5 -mt-6">
              <span class="flex items-center justify-center gap-2 rounded-full bg-paper py-3.5 text-sm font-semibold text-ink shadow-float transition-transform duration-300 group-hover:-translate-y-0.5">
                View Project
                <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <a
      href="/work"
      class="link-underline mt-12 inline-flex pb-1 text-sm font-semibold text-ink sm:hidden"
    >
      View all work
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </Container>
</Section>
