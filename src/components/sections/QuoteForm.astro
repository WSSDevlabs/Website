---
import Container from '../ui/Container.astro';
import { SERVICES } from '../../data/services';

const inputClass =
  'w-full rounded-xl border border-line bg-paper px-4 py-3 text-sm text-ink placeholder:text-muted shadow-card transition-all focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/25';
---

<section class="py-12 md:py-16">
  <Container>
    <div class="panel overflow-hidden">
      <div class="grid lg:grid-cols-2">
        <!-- Left: form -->
        <div class="p-8 md:p-12">
          <p class="mono-label text-accent">Contact us</p>
          <h2 class="h-section mt-4" data-split>Get your free quote today</h2>

          <form id="quote-form" class="mt-8 space-y-5" novalidate>
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="qf-name" class="mb-2 block text-sm font-semibold text-ink">
                  Your Name <span class="text-accent-red">*</span>
                </label>
                <input
                  id="qf-name"
                  type="text"
                  placeholder="Full name"
                  required
                  class={inputClass}
                />
              </div>
              <div>
                <label for="qf-email" class="mb-2 block text-sm font-semibold text-ink">
                  Email <span class="text-accent-red">*</span>
                </label>
                <input
                  id="qf-email"
                  type="email"
                  placeholder="you@company.com"
                  required
                  class={inputClass}
                />
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="qf-phone" class="mb-2 block text-sm font-semibold text-ink">Phone</label>
                <input
                  id="qf-phone"
                  type="tel"
                  placeholder="+60 11-000 0000"
                  class={inputClass}
                />
              </div>
              <div>
                <label for="qf-service" class="mb-2 block text-sm font-semibold text-ink">
                  Service Interested In
                </label>
                <select id="qf-service" class:list={[inputClass, 'appearance-none']}>
                  <option value="" disabled selected>Select service</option>
                  {SERVICES.map((s) => <option value={s.slug}>{s.title}</option>)}
                  <option value="others">Others</option>
                </select>
              </div>
            </div>

            <div>
              <label for="qf-message" class="mb-2 block text-sm font-semibold text-ink">
                Your Message
              </label>
              <textarea
                id="qf-message"
                rows="5"
                placeholder="Tell us what you're building"
                class:list={[inputClass, 'resize-none']}></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 text-sm font-semibold text-white shadow-[0_8px_20px_-8px_rgb(45_91_227/0.5)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-accent-dim"
            >
              Send Message
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </button>

            <p
              id="qf-success"
              class="hidden rounded-xl border border-accent-green/25 bg-accent-green/8 px-4 py-3 text-sm font-medium text-accent-green"
            >
              Thank you. We will get back to you within 1 business day.
            </p>
          </form>
        </div>

        <!-- Right: full-bleed image -->
        <div class="relative hidden overflow-hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&w=800&h=1000&q=80"
            alt="WSS DevLabs team ready to help"
            class="absolute inset-0 h-full w-full scale-110 object-cover"
            loading="lazy"
            width="800"
            height="1000"
            data-parallax="7"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-paper-dim/40 to-transparent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  function initQuoteForm() {
    const form = document.getElementById('quote-form') as HTMLFormElement | null;
    const success = document.getElementById('qf-success');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = '1';

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('qf-name') as HTMLInputElement)?.value.trim();
      const email = (document.getElementById('qf-email') as HTMLInputElement)?.value.trim();
      if (!name || !email) return;

      const service = (document.getElementById('qf-service') as HTMLSelectElement)?.value;
      const message = (document.getElementById('qf-message') as HTMLTextAreaElement)?.value.trim();
      const body = encodeURIComponent(`Name: ${name}\nService: ${service}\n\n${message}`);
      window.location.href = `mailto:hello@wssdevlabs.com?subject=Quote Request&body=${body}`;

      success?.classList.remove('hidden');
      form.reset();
    });
  }

  initQuoteForm();
  document.addEventListener('astro:page-load', initQuoteForm);
</script>
