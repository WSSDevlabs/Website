---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { SITE } from '../../data/site';
---

<Section rule class="pb-24 md:pb-32">
  <Container>
    <div class="flex flex-col items-start gap-12 md:flex-row md:items-center md:justify-between md:gap-16">
      <!-- Left: messaging -->
      <div class="max-w-md">
        <p class="mono-label text-accent">Get in touch</p>
        <h2 class="h-section mt-4" data-split>Ready to talk?</h2>
        <p class="mt-4 leading-relaxed text-ink-dim">
          Drop us a message and we will respond within one business day. No commitment required.
        </p>
      </div>

      <!-- Right: contact options -->
      <div class="flex w-full flex-col gap-4 md:w-auto md:min-w-96">
        {
          SITE.email && (
            <a
              href={`mailto:${SITE.email}`}
              class="card card-lift spotlight-card group flex items-center justify-between !rounded-2xl px-6 py-5"
            >
              <div class="flex items-center gap-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/8">
                  <svg class="h-4.5 w-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs text-ink-dim">Email us</p>
                  <p class="text-sm font-semibold text-ink">{SITE.email}</p>
                </div>
              </div>
              <svg class="h-4 w-4 text-ink-dim transition-all duration-300 group-hover:translate-x-1 group-hover:text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )
        }

        <a
          href="/contact"
          class="group flex items-center justify-between rounded-2xl bg-ink px-6 py-5 shadow-float transition-all duration-300 [transition-timing-function:var(--ease-out-expo)] hover:-translate-y-1 hover:shadow-[0_24px_48px_-16px_rgb(12_18_32/0.45)]"
        >
          <div class="flex items-center gap-4">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/10">
              <svg class="h-4.5 w-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
              </svg>
            </span>
            <span class="text-sm font-semibold text-white">Open contact form</span>
          </div>
          <svg class="h-4 w-4 text-white transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>

        <p class="flex items-center gap-2 px-1 text-sm text-ink-dim">
          <svg class="h-4 w-4 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          We reply within 1 business day
        </p>
      </div>
    </div>
  </Container>
</Section>
