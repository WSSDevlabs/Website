---
type Logo = { name: string; src: string };

type Props = {
  logos?: Logo[];
};

const { logos = [] } = Astro.props;
---

{
  logos.length > 0 && (
    <div class="border-y border-line bg-paper-dim py-10">
      <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-center gap-x-12 gap-y-6 px-6 md:px-10">
        {logos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 w-auto opacity-70 grayscale"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  )
}
