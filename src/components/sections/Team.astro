---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

type Member = { name: string; role: string; photo: ImageMetadata; credentials?: string };

type Props = {
  members?: Member[];
};

const { members = [] } = Astro.props;
---

{
  members.length > 0 && (
    <Section class="border-t border-line">
      <Container>
        <h2 class="text-2xl font-semibold tracking-tight text-ink">The team</h2>
        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {members.map((member) => (
            <div>
              <Image
                src={member.photo}
                alt={member.name}
                class="aspect-square w-full rounded-2xl object-cover"
              />
              <p class="mt-4 font-semibold text-ink">{member.name}</p>
              <p class="text-sm text-ink-dim">{member.role}</p>
              {member.credentials && <p class="mt-1 text-xs text-muted">{member.credentials}</p>}
            </div>
          ))}
        </div>
      </Container>
    </Section>
  )
}
