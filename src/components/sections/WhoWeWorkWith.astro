---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

const audiences = [
  {
    title: 'Startups launching',
    description:
      'A fast, credible first site or product build, moving quickly and leaving you with code you fully own.',
    toneClass: 'text-accent',
    bgClass: 'bg-accent/8',
    icon: 'M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z',
    img: 'https://picsum.photos/seed/startup-launch-tech/800/600',
    tags: ['Websites', 'MVPs', 'Branding']
  },
  {
    title: 'SMEs growing',
    description:
      'Systems built for where your business is headed, replacing outgrown templates and spreadsheets that hold it back.',
    toneClass: 'text-accent-yellow',
    bgClass: 'bg-accent-yellow/10',
    icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
    img: '',
    tags: ['Custom CMS', 'ERP', 'Mobile Apps']
  },
  {
    title: 'Companies needing AI',
    description:
      'Internal tools, CMS/ERP, and AI-powered features built to fit exactly how your business runs.',
    toneClass: 'text-accent-red',
    bgClass: 'bg-accent-red/8',
    icon: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z',
    img: '',
    tags: ['AI Integration', 'LLM', 'Automation']
  }
];

const [featured, ...rest] = audiences;
---

<Section rule>
  <Container>
    <h2 class="h-section" data-split>Built for builders</h2>

    <!-- Bento: featured left (row-span-2), two stacked right -->
    <div class="mt-12 grid gap-5 md:grid-cols-2 md:grid-rows-2" data-stagger>
      <a
        href="/contact"
        data-stagger-child
        class="card card-lift spotlight-card group flex min-h-64 flex-col overflow-hidden !rounded-3xl p-0 md:row-span-2"
      >
        <div class="relative h-48 overflow-hidden md:h-64">
          <img
            src={featured.img}
            alt="Startup workspace"
            class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
            loading="lazy"
            width="800"
            height="600"
          />
        </div>

        <div class="flex flex-1 flex-col p-7">
          <span class:list={['flex h-10 w-10 items-center justify-center rounded-xl', featured.bgClass]}>
            <svg class:list={['h-5 w-5', featured.toneClass]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={featured.icon} />
            </svg>
          </span>
          <h3 class="h-sub mt-4">{featured.title}</h3>
          <p class="mt-2.5 flex-1 leading-relaxed text-ink-dim">{featured.description}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {featured.tags.map((tag) => (
              <span class="mono-label rounded-md border border-line bg-paper-dim px-2.5 py-1 !text-[0.66rem] text-ink-dim">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </a>

      {
        rest.map((item) => (
          <a
            href="/contact"
            data-stagger-child
            class="card card-lift spotlight-card group flex flex-col !rounded-3xl p-7"
          >
            <span class:list={['flex h-10 w-10 items-center justify-center rounded-xl', item.bgClass]}>
              <svg class:list={['h-5 w-5', item.toneClass]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </span>
            <h3 class="mt-4 text-lg font-semibold tracking-tight text-ink">{item.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-dim">{item.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="mono-label rounded-md border border-line bg-paper-dim px-2.5 py-1 !text-[0.66rem] text-ink-dim">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Container>
</Section>
