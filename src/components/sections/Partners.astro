---
type Partner = { name: string; logo: string };

type Props = {
  partners?: Partner[];
};

const { partners = [] } = Astro.props;
---

{
  partners.length > 0 && (
    <div class="border-t border-line py-16">
      <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-center gap-x-12 gap-y-6 px-6 md:px-10">
        {partners.map((partner) => (
          <img
            src={partner.logo}
            alt={partner.name}
            class="h-10 w-auto opacity-70 grayscale"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  )
}
