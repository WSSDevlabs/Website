---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

const stacks = [
  {
    label: 'Web',
    description: 'Fast, typed, SEO-ready websites built with modern frameworks.',
    tone: 'blue',
    icon: 'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3 12c0 .778.099 1.533.284 2.253',
    tools: ['Astro', 'TypeScript', 'React', 'Next.js', 'Tailwind CSS'],
    img: 'https://picsum.photos/seed/web-dev-code/900/560'
  },
  {
    label: 'Mobile',
    description: 'Cross-platform and native apps for iOS and Android.',
    tone: 'yellow',
    icon: 'M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3',
    tools: ['React Native', 'Flutter', 'Swift', 'Kotlin']
  },
  {
    label: 'Systems',
    description: 'CMS, ERP, and internal tools shaped around your workflow.',
    tone: 'neutral',
    icon: 'M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z',
    tools: ['Node.js', 'PostgreSQL', 'REST / GraphQL', 'Custom CMS / ERP']
  },
  {
    label: 'AI',
    description: 'LLM features, RAG pipelines, and workflow automation.',
    tone: 'red',
    icon: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z',
    tools: ['LLM APIs', 'RAG pipelines', 'Automation', 'ML (where offered)']
  },
  {
    label: 'Marketing',
    description: 'SEO, paid ads, content strategy, and analytics setup.',
    tone: 'green',
    icon: 'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6',
    tools: ['Google Ads', 'Meta Ads', 'SEO', 'Content Strategy', 'GA4']
  },
  {
    label: 'Creative',
    description: 'Brand identity, photography, video, and social content.',
    tone: 'yellow',
    icon: 'm2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z',
    tools: ['Adobe Suite', 'Figma', 'Premiere Pro', 'After Effects', 'Canva']
  }
];

const toneIcon: Record<string, string> = {
  blue: 'text-accent',
  yellow: 'text-accent-yellow',
  neutral: 'text-ink-dim',
  red: 'text-accent-red',
  green: 'text-accent-green'
};
const toneBg: Record<string, string> = {
  blue: 'bg-accent/8',
  yellow: 'bg-accent-yellow/10',
  neutral: 'bg-ink/5',
  red: 'bg-accent-red/8',
  green: 'bg-accent-green/8'
};

const [featured, ...rest] = stacks;
---

<Section rule class="bg-paper-dim">
  <Container>
    <h2 class="h-section" data-split>Tech and tools we work with</h2>

    <!-- Bento grid: featured image card + 5 compact cards -->
    <div class="mt-12 grid gap-5 md:grid-cols-3" data-stagger>
      <!-- Featured web card with image -->
      <div
        data-stagger-child
        class="card card-lift spotlight-card group relative flex flex-col overflow-hidden !rounded-3xl p-0 md:row-span-2"
      >
        <div class="relative h-48 overflow-hidden">
          <img
            src={featured.img}
            alt="Web development"
            class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
            loading="lazy"
            width="900"
            height="560"
          />
        </div>
        <div class="flex flex-1 flex-col p-7">
          <span class:list={['flex h-10 w-10 items-center justify-center rounded-xl', toneBg[featured.tone]]}>
            <svg class:list={['h-5 w-5', toneIcon[featured.tone]]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={featured.icon} />
            </svg>
          </span>
          <p class="mt-4 text-lg font-semibold tracking-tight text-ink">{featured.label}</p>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-dim">{featured.description}</p>
          <div class="mt-5 flex flex-1 flex-wrap content-start gap-2">
            {featured.tools.map((tool) => (
              <span class="mono-label rounded-md border border-line bg-paper-dim px-2.5 py-1 !text-[0.66rem] text-ink-dim">
                {tool}
              </span>
            ))}
          </div>
        </div>
      </div>

      {
        rest.map((stack) => (
          <div
            data-stagger-child
            class="card card-lift spotlight-card flex items-start gap-4 p-6"
          >
            <span class:list={['flex h-10 w-10 shrink-0 items-center justify-center rounded-xl', toneBg[stack.tone]]}>
              <svg class:list={['h-4.5 w-4.5', toneIcon[stack.tone]]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d={stack.icon} />
              </svg>
            </span>
            <div class="min-w-0 flex-1">
              <p class="font-semibold tracking-tight text-ink">{stack.label}</p>
              <p class="mt-1 text-sm leading-relaxed text-ink-dim">{stack.description}</p>
              <p class="mono-label mt-3 !text-[0.66rem] !normal-case !tracking-normal text-muted">
                {stack.tools.slice(0, 3).join('  /  ')}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
