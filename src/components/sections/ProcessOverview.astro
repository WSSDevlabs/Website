---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import { PROCESS_PHASES } from '../../data/process';
---

<Section rule>
  <Container>
    <!-- Asymmetric bento: intro + tall photo + three phase cards -->
    <div class="grid gap-5 lg:grid-cols-3 lg:grid-rows-2">
      <!-- Intro cell -->
      <div class="flex flex-col justify-between rounded-3xl border border-line bg-paper-dim p-8 lg:col-start-1 lg:row-start-1">
        <div>
          <h2 class="h-section" data-split>Step-by-step to your goal</h2>
          <p class="mt-4 text-sm leading-relaxed text-ink-dim" data-color-reveal>
            Every project follows a <span data-accent>structured three-phase approach</span>, so
            you always know where things stand and what comes next.
          </p>
        </div>
        <span
          class="mt-8 flex h-11 w-11 items-center justify-center rounded-full border border-line bg-paper text-ink"
          aria-hidden="true"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </span>
      </div>

      <!-- Tall photo cell -->
      <div
        class="relative hidden overflow-hidden rounded-3xl border border-line shadow-card lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:block"
        data-reveal="tilt3d"
      >
        <img
          src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&h=1080&q=80"
          alt="The team mapping out a project plan"
          class="h-full w-full scale-110 object-cover"
          loading="lazy"
          width="800"
          height="1080"
          data-parallax="9"
        />
      </div>

      <!-- Phase cards -->
      {
        PROCESS_PHASES.map((phase, index) => (
          <div
            class:list={[
              'tilt-card spotlight-card card flex flex-col rounded-3xl p-7',
              index === 0 && 'lg:col-start-3 lg:row-start-1',
              index === 1 && 'lg:col-start-1 lg:row-start-2',
              index === 2 && 'lg:col-start-3 lg:row-start-2'
            ]}
            data-reveal="tilt3d"
            data-reveal-delay={index * 0.08}
          >
            <span class="stat-num inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-sm text-accent">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="h-sub mt-5">{phase.phase}</h3>
            <p class="mt-2.5 flex-1 text-sm leading-relaxed text-ink-dim">{phase.summary}</p>
          </div>
        ))
      }
    </div>

    <Button href="/process" variant="secondary" class="mt-10">See the full process</Button>
  </Container>
</Section>
