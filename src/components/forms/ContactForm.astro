---
const PROJECT_TYPES = [
  'Website',
  'Mobile App',
  'Custom System (CMS/ERP)',
  'AI Development',
  'UI/UX',
  'Maintenance',
  'Not sure'
];
const BUDGET_RANGES = [
  'Under RM10,000',
  'RM10,000 – RM30,000',
  'RM30,000 – RM80,000',
  'RM80,000+',
  'Not sure yet'
];
const REFERRAL_SOURCES = ['Google search', 'Social media', 'Referral', 'LinkedIn', 'Other'];
---

<form id="contact-form" class="space-y-6" novalidate>
  <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY} />
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    style="display:none"
    tabindex="-1"
    autocomplete="off"
  />

  <div class="grid gap-6 sm:grid-cols-2">
    <div>
      <label for="name" class="text-sm font-medium text-ink">Name</label>
      <input id="name" name="name" type="text" required class="form-input" />
    </div>
    <div>
      <label for="email" class="text-sm font-medium text-ink">Email</label>
      <input id="email" name="email" type="email" required class="form-input" />
    </div>
    <div>
      <label for="phone" class="text-sm font-medium text-ink">Phone (optional)</label>
      <input id="phone" name="phone" type="tel" class="form-input" />
    </div>
    <div>
      <label for="company" class="text-sm font-medium text-ink">Company (optional)</label>
      <input id="company" name="company" type="text" class="form-input" />
    </div>
  </div>

  <fieldset>
    <legend class="text-sm font-medium text-ink">Project type</legend>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        PROJECT_TYPES.map((type) => (
          <label class="flex cursor-pointer items-center gap-2 rounded-full border border-line px-4 py-2 text-sm text-ink-dim has-checked:border-accent has-checked:text-accent">
            <input type="checkbox" name="project_type" value={type} class="sr-only" />
            {type}
          </label>
        ))
      }
    </div>
  </fieldset>

  <div class="grid gap-6 sm:grid-cols-2">
    <div>
      <label for="budget" class="text-sm font-medium text-ink">Budget range</label>
      <select id="budget" name="budget" class="form-input">
        <option value="">Select a range</option>
        {BUDGET_RANGES.map((range) => <option value={range}>{range}</option>)}
      </select>
    </div>
    <div>
      <label for="referral" class="text-sm font-medium text-ink">How did you hear about us?</label>
      <select id="referral" name="referral" class="form-input">
        <option value="">Select an option</option>
        {REFERRAL_SOURCES.map((source) => <option value={source}>{source}</option>)}
      </select>
    </div>
  </div>

  <div>
    <label for="message" class="text-sm font-medium text-ink">Message</label>
    <textarea id="message" name="message" rows="5" required class="form-input"></textarea>
  </div>

  <label class="flex items-start gap-3 text-sm text-ink-dim">
    <input type="checkbox" name="pdpa_consent" required class="mt-1" />
    I consent to WSS DevLabs collecting and processing this information in accordance with the
    <a href="/privacy" class="underline hover:text-accent">Privacy Policy</a>, as required under the
    PDPA 2010.
  </label>

  <button id="contact-submit" type="submit" class="btn-primary">
    <span id="contact-submit-label">Send message</span>
  </button>

  <p id="contact-form-status" role="status" aria-live="polite" class="text-sm"></p>
</form>

<style>
  .form-input {
    margin-top: 0.5rem;
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid var(--color-line);
    background-color: var(--color-paper-dim);
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--color-ink);
  }
  .form-input:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .btn-primary {
    border-radius: 9999px;
    background-color: var(--color-accent);
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    cursor: pointer;
  }
  .btn-primary:hover {
    background-color: var(--color-accent-dim);
  }
  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitButton = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('contact-submit-label');
  const status = document.getElementById('contact-form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submitButton || !submitLabel || !status) return;

    const botcheck = form.querySelector<HTMLInputElement>('input[name="botcheck"]');
    if (botcheck?.checked) return;

    submitButton.disabled = true;
    submitLabel.textContent = 'Sending…';
    status.textContent = '';
    status.className = 'text-sm';

    try {
      const formData = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: formData
      });
      const result = await response.json();

      if (result.success) {
        status.textContent = "Thanks, we'll get back to you within one business day.";
        status.classList.add('text-ink');
        form.reset();
      } else {
        throw new Error(result.message ?? 'Submission failed');
      }
    } catch {
      status.textContent =
        'Something went wrong sending your message. Please try again or email us directly.';
      status.classList.add('text-accent');
    } finally {
      submitButton.disabled = false;
      submitLabel.textContent = 'Send message';
    }
  });
</script>
