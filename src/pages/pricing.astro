---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import FAQ from '../components/sections/FAQ.astro';
import { PRICING_TIERS } from '../data/pricing';
import { PRICING_FAQ } from '../data/faq';
---

<BaseLayout
  title="Pricing: WSS DevLabs"
  description="Transparent project-based pricing for web development, mobile apps, custom systems, and AI-powered software. Fixed-price proposals, no surprises."
  path="/pricing"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="dot-pattern mask-fade-edges absolute inset-0" aria-hidden="true" />
    <Container class="relative py-14 md:py-20">
      <h1 class="h-display mt-6" data-split>Pricing that scopes to the <span class="text-accent-red">work</span></h1>
      <p class="body-lead mt-5">
        Three starting tiers, fixed-price proposals, and no surprises after kickoff.
      </p>
    </Container>
    <div class="hairline absolute inset-x-0 bottom-0" aria-hidden="true" />
  </section>

  <!-- Pricing cards -->
  <Section rule>
    <Container>
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {
          PRICING_TIERS.map((tier) => (
            <div
              data-stagger-child
              class:list={[
                'relative flex flex-col rounded-3xl bg-paper-dim p-8 transition-all duration-300 [transition-timing-function:var(--ease-out-expo)]',
                tier.highlight ? 'ring-2 ring-accent' : 'ring-1 ring-line',
              ]}
            >
              {tier.badge && (
                <span class="absolute -top-3 left-8 rounded-full bg-accent px-4 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow-card">
                  {tier.badge}
                </span>
              )}

              <p class="text-sm font-bold text-ink">{tier.name}</p>

              <p class="stat-num mt-3 text-4xl text-ink">{tier.price}</p>

              <p class="mt-2 text-sm italic leading-relaxed text-ink-dim">{tier.description}</p>

              <div class="hairline my-6" aria-hidden="true" />

              <ul class="flex-1 space-y-2.5">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2.5 text-sm text-ink-dim">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={tier.ctaHref}
                class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-ink px-6 py-3.5 text-sm font-semibold text-white transition-all duration-300 [transition-timing-function:var(--ease-out-expo)] hover:-translate-y-0.5 hover:bg-ink/85"
              >
                {tier.cta}
              </a>
            </div>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-ink-dim">
        All prices in Malaysian Ringgit (RM). Projects are scoped individually, so these are starting points.{' '}
        <a href="/contact" class="font-semibold text-accent hover:underline">Request an accurate quote</a>
      </p>
    </Container>
  </Section>

  <FAQ title="Freely ask us for more information" items={PRICING_FAQ} />

  <QuoteForm />

</BaseLayout>
