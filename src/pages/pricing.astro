---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import FAQ from '../components/sections/FAQ.astro';
import { PRICING_TIERS } from '../data/pricing';
import { PRICING_FAQ } from '../data/faq';
---

<BaseLayout
  title="Pricing: WSS DevLabs"
  description="Transparent project-based pricing for web development, mobile apps, custom systems, and AI-powered software. Fixed-price proposals, no surprises."
  path="/pricing"
>

  <!-- Pricing cards -->
  <Section rule>
    <Container>
      <div class="grid gap-6 md:grid-cols-3 md:items-start" data-stagger>
        {
          PRICING_TIERS.map((tier) => (
            <div
              data-stagger-child
              data-reveal={tier.highlight ? 'tilt3d' : undefined}
              class:list={[
                'relative flex flex-col rounded-3xl p-8 transition-all duration-300 [transition-timing-function:var(--ease-out-expo)]',
                tier.highlight
                  ? 'bg-charcoal text-white shadow-2xl shadow-black/30 md:-translate-y-3'
                  : 'bg-paper-dim text-ink ring-1 ring-line'
              ]}
            >
              {tier.badge && (
                <span
                  class:list={[
                    'absolute -top-3 left-8 rounded-full px-4 py-1 text-xs font-semibold uppercase tracking-wide shadow-card',
                    tier.highlight ? 'bg-accent text-white' : 'bg-ink text-white'
                  ]}
                >
                  {tier.badge}
                </span>
              )}

              <p class:list={['text-sm font-bold', tier.highlight ? 'text-white' : 'text-ink']}>{tier.name}</p>

              <p class:list={['num-feature mt-3 text-4xl', tier.highlight ? 'text-white' : 'text-ink']}>{tier.price}</p>

              <p class:list={['mt-2 text-sm italic leading-relaxed', tier.highlight ? 'text-white/60' : 'text-ink-dim']}>{tier.description}</p>

              <div class:list={['my-6 h-px', tier.highlight ? 'bg-white/10' : 'hairline']} aria-hidden="true" />

              <ul class="flex-1 space-y-2.5">
                {tier.features.map((feature) => (
                  <li class:list={['flex items-start gap-2.5 text-sm', tier.highlight ? 'text-white/75' : 'text-ink-dim']}>
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={tier.ctaHref}
                class:list={[
                  'mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-all duration-300 [transition-timing-function:var(--ease-out-expo)] hover:-translate-y-0.5',
                  tier.highlight ? 'bg-accent text-white hover:bg-accent-dim' : 'bg-charcoal text-white hover:bg-charcoal-soft'
                ]}
              >
                {tier.cta}
              </a>
            </div>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-ink-dim">
        All prices in Malaysian Ringgit (RM). Projects are scoped individually, so these are starting points.{' '}
        <a href="/contact" class="font-semibold text-accent hover:underline">Request an accurate quote</a>
      </p>
    </Container>
  </Section>

  <FAQ title="Freely ask us for more information" items={PRICING_FAQ} />

  <QuoteForm />

</BaseLayout>
