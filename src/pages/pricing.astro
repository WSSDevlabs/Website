---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import NewsletterBand from '../components/sections/NewsletterBand.astro';
import { PRICING_TIERS } from '../data/pricing';
---

<BaseLayout
  title="Pricing: WSS DevLabs"
  description="Transparent project-based pricing for web development, mobile apps, custom systems, and AI-powered software. Fixed-price proposals, no surprises."
  path="/pricing"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="dot-pattern mask-fade-edges absolute inset-0" aria-hidden="true" />
    <Container class="relative py-14 md:py-20">
      <h1 class="h-display mt-6" data-split>Pricing that scopes to the work</h1>
      <p class="body-lead mt-5">
        Three starting tiers, fixed-price proposals, and no surprises after kickoff.
      </p>
    </Container>
    <div class="hairline absolute inset-x-0 bottom-0" aria-hidden="true" />
  </section>

  <!-- Pricing cards -->
  <Section rule>
    <Container>
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {
          PRICING_TIERS.map((tier) => (
            <div
              data-stagger-child
              class:list={[
                'relative flex flex-col rounded-3xl border p-8 transition-all duration-300 [transition-timing-function:var(--ease-out-expo)]',
                tier.highlight
                  ? 'border-transparent bg-ink text-white shadow-[0_32px_80px_-40px_rgb(12_18_32/0.55)]'
                  : 'card card-lift',
              ]}
            >
              {tier.badge && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent px-4 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow-card">
                  {tier.badge}
                </span>
              )}

              <p class:list={['mono-label', tier.highlight ? 'text-white/60' : 'text-accent']}>
                {tier.name}
              </p>

              <p class:list={['stat-num mt-3 text-4xl', tier.highlight ? 'text-white' : 'text-ink']}>
                {tier.price}
              </p>

              <p class:list={['mt-2 text-sm leading-relaxed', tier.highlight ? 'text-white/60' : 'text-ink-dim']}>
                {tier.description}
              </p>

              <div class:list={['hairline my-6', tier.highlight && '!bg-white/10']} aria-hidden="true" />

              <ul class="flex-1 space-y-2.5">
                {tier.features.map((feature) => (
                  <li class:list={['flex items-start gap-2.5 text-sm', tier.highlight ? 'text-white/75' : 'text-ink-dim']}>
                    <svg
                      class:list={['mt-0.5 h-4 w-4 shrink-0', tier.highlight ? 'text-white' : 'text-accent']}
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.4"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={tier.ctaHref}
                class:list={[
                  'mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-all duration-300 [transition-timing-function:var(--ease-out-expo)] hover:-translate-y-0.5',
                  tier.highlight
                    ? 'bg-accent text-white hover:bg-accent-dim'
                    : 'border border-line text-ink shadow-card hover:border-ink/25 hover:shadow-card-hover',
                ]}
              >
                {tier.cta}
              </a>
            </div>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-ink-dim">
        All prices in Malaysian Ringgit (RM). Projects are scoped individually, so these are starting points.{' '}
        <a href="/contact" class="font-semibold text-accent hover:underline">Request an accurate quote</a>
      </p>
    </Container>
  </Section>

  <QuoteForm />

  <NewsletterBand />
</BaseLayout>
