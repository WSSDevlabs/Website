---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { TEAM, getTeamMemberBySlug } from '../../data/team';

export function getStaticPaths() {
  return TEAM.map((member) => ({ params: { slug: member.slug } }));
}

const { slug } = Astro.params;
const member = getTeamMemberBySlug(slug);

if (!member) return Astro.redirect('/team');
---

<BaseLayout
  title={`${member.name}: ${member.role}`}
  description={`${member.name} is a ${member.role} at WSS DevLabs. ${member.bio.slice(0, 120)}…`}
  path={`/team/${member.slug}`}
>
  <!-- Profile hero -->
  <section class="border-b border-line bg-paper-dim">
    <Container class="py-16 md:py-24">
      <div class="flex flex-col gap-10 md:flex-row md:items-center">
        <div class="h-40 w-40 shrink-0 overflow-hidden rounded-2xl md:h-56 md:w-56">
          <img
            src={member.photo}
            alt={member.name}
            class="h-full w-full object-cover"
          />
        </div>
        <div>
          <Eyebrow label="Our Team" />
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">{member.name}</h1>
          <p class="mt-1 text-lg text-accent">{member.role}</p>
          {member.credentials && <p class="mt-1 text-sm text-ink-dim">{member.credentials}</p>}
          <div class="mt-5 flex gap-3">
            {member.social?.linkedin && (
              <a href={member.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim hover:border-accent hover:text-accent">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            )}
            {member.social?.github && (
              <a href={member.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim hover:border-accent hover:text-accent">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                </svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Bio -->
  <Section>
    <Container class="max-w-3xl">
      <Eyebrow label="About" />
      <p class="mt-4 text-lg leading-relaxed text-ink-dim">{member.bio}</p>
    </Container>
  </Section>

  <!-- Skills -->
  {
    member.skills && member.skills.length > 0 && (
      <Section class="border-t border-line bg-paper-dim">
        <Container class="max-w-3xl">
          <Eyebrow label="Skills & tools" />
          <div class="mt-6 flex flex-wrap gap-2">
            {member.skills.map((skill) => (
              <span class="rounded-full border border-line bg-paper px-4 py-1.5 text-sm text-ink-dim">
                {skill}
              </span>
            ))}
          </div>
        </Container>
      </Section>
    )
  }

  <CTABand
    title={`Work with ${member.name.split(' ')[0]}`}
    subtitle="Have a project in mind? Let's see if we're a fit."
  />
</BaseLayout>
