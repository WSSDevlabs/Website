---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const placeholders = [
  { id: 'ph-1', title: "A Beginner's Guide to Running Profitable Ad Campaigns: Strategies That Actually Work", category: 'Paid Advertising', date: '15 May 2025', img: 'team-coding-laptop', excerpt: 'Everything you need to know about running ads that convert, from initial setup to scaling your campaigns profitably.' },
  { id: 'ph-2', title: 'Top 10 SEO Strategies That Still Work in 2025', category: 'SEO', date: '14 May 2025', img: 'developer-monitor-code', excerpt: 'Cut through the noise with proven SEO techniques that drive organic traffic and rank your site consistently.' },
  { id: 'ph-3', title: 'Why Long-Form Content Dominates Search Results in 2025', category: 'Content Marketing', date: '13 May 2025', img: 'person-writing-laptop', excerpt: 'Quality and depth beat thin content every time. Here is how to structure long-form pieces that rank and convert.' },
  { id: 'ph-4', title: 'Mastering Instagram Marketing for Small Business Growth', category: 'Social Media', date: '12 May 2025', img: 'social-media-phone', excerpt: 'How small businesses can grow organically on Instagram without a massive budget in the current landscape.' },
  { id: 'ph-5', title: 'The Role of Branding Consistency in Digital Marketing', category: 'Branding', date: '11 May 2025', img: 'branding-design-workspace', excerpt: 'Consistent branding builds trust and recognition. Here is how a strong visual identity multiplies your marketing ROI.' },
];

const recentPosts = [
  { title: 'How to Perform a Full SEO Audit in 2025', date: '19 May 2025', img: 'seo-audit-checklist' },
  { title: '5 Common PPC Mistakes That Drain Your Budget', date: '17 May 2025', img: 'ppc-campaign-dashboard' },
  { title: 'How to Write SEO-Friendly Blog Posts That Convert', date: '15 May 2025', img: 'content-writing-tech' },
];

const popularTags = ['SEO', 'Web Development', 'Social Media', 'Paid Ads', 'Branding', 'AI & Automation', 'Content Marketing', 'Mobile Apps'];

const catColor: Record<string, string> = {
  'Paid Advertising': 'bg-accent-yellow',
  'SEO': 'bg-accent-blue',
  'Content Marketing': 'bg-accent',
  'Social Media': 'bg-accent-green',
  'Branding': 'bg-accent-blue',
};
---

<BaseLayout
  title="Blogs & Insights: WSS DevLabs"
  description="Practical guides on web development, AI, digital marketing, and business growth from the WSS DevLabs team."
  path="/insights"
>

  <!-- 2-col layout -->
  <section class="border-b border-line">
    <Container class="py-10">
      <div class="grid gap-10 lg:grid-cols-3">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <h2 class="text-xl font-bold text-ink">Our Latest News &amp; Blogs</h2>

          <div class="mt-6 space-y-8">
            {
              posts.length > 0
                ? posts.map((post) => (
                    <a href={`/insights/${post.id}`} class="tilt-card group block overflow-hidden rounded-2xl border border-line bg-paper shadow-sm transition-all hover:border-accent/30 hover:shadow-md">
                      <div class="relative overflow-hidden">
                        <Image
                          src={post.data.coverImage}
                          alt={post.data.title}
                          class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                          width={700}
                          height={380}
                        />
                        <div class="absolute bottom-3 left-3 flex items-center gap-2">
                          <span class:list={['rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white', catColor[post.data.tags[0] ?? 'SEO'] ?? 'bg-accent']}>
                            {post.data.tags[0] ?? 'Insight'}
                          </span>
                          <span class="rounded-full bg-ink/70 px-2.5 py-1 text-[10px] text-white backdrop-blur-sm">
                            {post.data.publishDate.toLocaleDateString('en-MY', { day: 'numeric', month: 'short', year: 'numeric' })}
                          </span>
                        </div>
                        <span class="absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-accent text-white shadow-md">
                          <svg class="h-4 w-4 -rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                        </span>
                      </div>
                      <div class="p-5">
                        <h3 class="text-base font-bold text-ink transition-colors group-hover:text-accent">{post.data.title}</h3>
                        <p class="mt-2 text-sm text-ink-dim">{post.data.description}</p>
                        <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-accent">
                          Read More
                          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                        </span>
                      </div>
                    </a>
                  ))
                : placeholders.map((ph) => (
                    <div class="tilt-card group overflow-hidden rounded-2xl border border-line bg-paper shadow-sm">
                      <div class="relative overflow-hidden">
                        <img
                          src={`https://picsum.photos/seed/${ph.img}/700/380`}
                          alt={ph.title}
                          loading="lazy"
                          width="700"
                          height="380"
                          class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                        <div class="absolute bottom-3 left-3 flex items-center gap-2">
                          <span class:list={['rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white', catColor[ph.category] ?? 'bg-accent']}>
                            {ph.category}
                          </span>
                          <span class="rounded-full bg-ink/70 px-2.5 py-1 text-[10px] text-white backdrop-blur-sm">
                            {ph.date}
                          </span>
                        </div>
                        <span class="absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-accent text-white shadow-md">
                          <svg class="h-4 w-4 -rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                        </span>
                      </div>
                      <div class="p-5">
                        <h3 class="text-base font-bold text-ink">{ph.title}</h3>
                        <p class="mt-2 text-sm text-ink-dim">{ph.excerpt}</p>
                        <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-accent">
                          Read More
                          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                        </span>
                      </div>
                    </div>
                  ))
            }
          </div>

          <!-- Pagination -->
          <nav class="mt-10 flex items-center justify-center gap-1" aria-label="Pagination">
            <button type="button" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-colors hover:border-accent hover:text-accent">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
            </button>
            {[1, 2, 3].map((n) => (
              <button
                type="button"
                class:list={[
                  'flex h-9 w-9 items-center justify-center rounded-full text-sm font-semibold transition-colors',
                  n === 1 ? 'bg-accent text-white' : 'border border-line text-ink-dim hover:border-accent hover:text-accent',
                ]}
              >
                {n}
              </button>
            ))}
            <span class="px-1 text-ink-dim">...</span>
            <button type="button" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-sm font-semibold text-ink-dim transition-colors hover:border-accent hover:text-accent">10</button>
            <button type="button" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-colors hover:border-accent hover:text-accent">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
            </button>
          </nav>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Search -->
          <div class="rounded-2xl border border-line bg-paper p-5 shadow-sm">
            <h3 class="text-sm font-bold text-ink">Search Posts</h3>
            <div class="mt-3 flex gap-2">
              <input
                type="text"
                placeholder="Search..."
                class="flex-1 rounded-xl border border-line bg-paper-dim px-3 py-2 text-sm text-ink placeholder:text-ink-dim focus:border-accent focus:outline-none"
              />
              <button type="button" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-accent text-white transition-colors hover:bg-accent-dim">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
              </button>
            </div>
          </div>

          <!-- Popular Tags -->
          <div class="rounded-2xl border border-line bg-paper p-5 shadow-sm">
            <h3 class="text-sm font-bold text-ink">Popular Tags</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {popularTags.map((tag, i) => (
                <button
                  type="button"
                  class:list={[
                    'rounded-full px-3 py-1.5 text-xs font-medium transition-colors',
                    i === 0 ? 'bg-accent text-white' : 'border border-line text-ink-dim hover:border-accent hover:text-accent',
                  ]}
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>

          <!-- Recent Posts -->
          <div class="rounded-2xl border border-line bg-paper p-5 shadow-sm">
            <h3 class="text-sm font-bold text-ink">Recent Posts</h3>
            <div class="mt-3 space-y-4">
              {recentPosts.map((p) => (
                <div class="flex items-start gap-3">
                  <div class="h-14 w-14 shrink-0 overflow-hidden rounded-lg">
                    <img
                      src={`https://picsum.photos/seed/${p.img}/100/100`}
                      alt={p.title}
                      width="100"
                      height="100"
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                  <div class="min-w-0">
                    <p class="line-clamp-2 text-xs font-semibold leading-snug text-ink hover:text-accent">{p.title}</p>
                    <p class="mt-1 text-[10px] text-ink-dim">{p.date}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- CTA card -->
          <div class="overflow-hidden rounded-2xl bg-ink p-6 text-white">
            <div class="relative">
              <img
                src="https://picsum.photos/seed/tech-team-meeting/400/250"
                alt=""
                class="mb-4 h-32 w-full rounded-xl object-cover"
                loading="lazy"
                width="400"
                height="250"
              />
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/50">Hire Us</p>
              <h3 class="mt-1 text-base font-bold text-white leading-snug">Need Help With Your Next Build?</h3>
              <a
                href="/contact"
                class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-accent py-2.5 text-sm font-bold text-white transition-colors hover:bg-accent-dim"
              >
                Start a Project
              </a>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

</BaseLayout>
