---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import CTABand from '../../components/sections/CTABand.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const placeholders = [
  { id: 'ph-1', title: "A Beginner's Guide to Running Profitable Ad Campaigns: Strategies That Actually Work", category: 'Paid Advertising', date: '15 May 2025', img: 'team-coding-laptop', excerpt: 'Everything you need to know about running ads that convert, from initial setup to scaling your campaigns profitably.' },
  { id: 'ph-2', title: 'Top 10 SEO Strategies That Still Work in 2025', category: 'SEO', date: '14 May 2025', img: 'developer-monitor-code', excerpt: 'Cut through the noise with proven SEO techniques that drive organic traffic and rank your site consistently.' },
  { id: 'ph-3', title: 'Why Long-Form Content Dominates Search Results in 2025', category: 'Content Marketing', date: '13 May 2025', img: 'person-writing-laptop', excerpt: 'Quality and depth beat thin content every time. Here is how to structure long-form pieces that rank and convert.' },
  { id: 'ph-4', title: 'Mastering Instagram Marketing for Small Business Growth', category: 'Social Media', date: '12 May 2025', img: 'social-media-phone', excerpt: 'How small businesses can grow organically on Instagram without a massive budget in the current landscape.' },
  { id: 'ph-5', title: 'The Role of Branding Consistency in Digital Marketing', category: 'Branding', date: '11 May 2025', img: 'branding-design-workspace', excerpt: 'Consistent branding builds trust and recognition. Here is how a strong visual identity multiplies your marketing ROI.' },
  { id: 'ph-6', title: 'The Real Cost of Skipping a Design System Early On', category: 'Web Development', date: '9 May 2025', img: 'design-system-tokens', excerpt: 'What breaks first when a growing product never invests in shared components, and when it is actually worth the detour.' },
  { id: 'ph-7', title: 'How to Brief an Agency So You Actually Get What You Want', category: 'Web Development', date: '7 May 2025', img: 'client-briefing-notes', excerpt: 'The difference between a smooth build and a painful one usually comes down to the brief. Here is how to write a good one.' },
  { id: 'ph-8', title: 'What a Malaysian SME Should Budget for a First Website', category: 'Business Growth', date: '5 May 2025', img: 'sme-budget-planning', excerpt: 'Realistic starting costs, what drives the price up, and where it is safe to cut corners on a first build.' }
];

type FeedItem = {
  id: string;
  title: string;
  excerpt: string;
  category: string;
  dateLabel: string;
  readMinutes: number;
  isReal: boolean;
  realImage?: (typeof posts)[number]['data']['coverImage'];
  fallbackImage?: string;
};

const estimateReadMinutes = (text: string) => Math.max(3, Math.round(text.split(/\s+/).length / 15));

const feedItems: FeedItem[] =
  posts.length > 0
    ? posts.map((post) => ({
        id: post.id,
        title: post.data.title,
        excerpt: post.data.description,
        category: post.data.tags[0] ?? 'Insight',
        dateLabel: post.data.publishDate.toLocaleDateString('en-MY', { day: 'numeric', month: 'short', year: 'numeric' }),
        readMinutes: estimateReadMinutes(post.data.description),
        isReal: true,
        realImage: post.data.coverImage
      }))
    : placeholders.map((ph) => ({
        id: ph.id,
        title: ph.title,
        excerpt: ph.excerpt,
        category: ph.category,
        dateLabel: ph.date,
        readMinutes: estimateReadMinutes(ph.title + ' ' + ph.excerpt),
        isReal: false,
        fallbackImage: `https://picsum.photos/seed/${ph.img}/720/440`
      }));

const [featured, ...rest] = feedItems;
const latest = rest.slice(0, 4);
const more = rest.slice(4, 7);
---

<BaseLayout
  title="Insights: WSS DevLabs"
  description="Notes from the WSS DevLabs team on web development, AI, digital marketing, and business growth."
  path="/insights"
>
  <!-- Featured post + latest list -->
  <section class="border-b border-line">
    <Container class="py-10 md:py-14">
      <div class="grid gap-6 lg:grid-cols-3">
        <!-- Featured -->
        <a
          href={featured.isReal ? `/insights/${featured.id}` : undefined}
          class:list={['group relative block overflow-hidden rounded-3xl lg:col-span-2', !featured.isReal && 'cursor-default']}
        >
          <div class="relative aspect-[4/3] sm:aspect-[16/10]">
            {featured.isReal && featured.realImage ? (
              <Image
                src={featured.realImage}
                alt={featured.title}
                class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
                width={900}
                height={560}
              />
            ) : (
              <img
                src={featured.fallbackImage}
                alt={featured.title}
                loading="eager"
                width="900"
                height="560"
                class="h-full w-full object-cover transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:scale-105"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/25 to-transparent" aria-hidden="true"></div>
            <span class="absolute left-5 top-5 inline-flex items-center gap-1.5 rounded-full bg-paper/95 px-3 py-1.5 text-xs font-semibold text-ink">
              <span class="h-1.5 w-1.5 rounded-full bg-accent-red" aria-hidden="true"></span>
              {featured.category}
            </span>
            <div class="absolute inset-x-0 bottom-0 p-6 md:p-8">
              <h1 class="h-sub text-white">{featured.title}</h1>
              <p class="mt-2 text-xs text-white/60">{featured.dateLabel} &middot; {featured.readMinutes} min read</p>
            </div>
          </div>
        </a>

        <!-- Latest post list -->
        <div>
          <h2 class="text-sm font-bold uppercase tracking-wide text-ink">Latest post</h2>
          <div class="mt-5 space-y-5">
            {
              latest.map((item) => (
                <a
                  href={item.isReal ? `/insights/${item.id}` : undefined}
                  class:list={['group flex items-start gap-3', !item.isReal && 'cursor-default']}
                >
                  <div class="h-16 w-16 shrink-0 overflow-hidden rounded-xl">
                    {item.isReal && item.realImage ? (
                      <Image src={item.realImage} alt={item.title} class="h-full w-full object-cover" width={100} height={100} />
                    ) : (
                      <img src={item.fallbackImage} alt={item.title} loading="lazy" width="100" height="100" class="h-full w-full object-cover" />
                    )}
                  </div>
                  <div class="min-w-0">
                    <p class="line-clamp-2 text-sm font-semibold leading-snug text-ink transition-colors group-hover:text-accent">{item.title}</p>
                    <p class="mt-1.5 text-xs text-ink-dim">{item.dateLabel} &middot; {item.readMinutes} min read</p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- More from WSS DevLabs: carousel -->
  {
    more.length > 0 && (
      <section class="border-b border-line bg-paper-dim">
        <Container class="py-10 md:py-14">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-bold uppercase tracking-wide text-ink">More from WSS DevLabs</h2>
            <div class="flex gap-2">
              <button
                type="button"
                aria-label="Previous"
                data-more-prev
                class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-paper text-ink transition-colors hover:bg-ink hover:text-white"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
              </button>
              <button
                type="button"
                aria-label="Next"
                data-more-next
                class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-paper text-ink transition-colors hover:bg-ink hover:text-white"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </button>
            </div>
          </div>

          <div class="mt-8 mask-fade-x -mx-6 px-6 md:-mx-10 md:px-10">
            <div class="flex gap-5 overflow-x-auto pb-2 snap-x snap-mandatory [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-more-track>
              {
                more.map((item) => (
                  <a
                    href={item.isReal ? `/insights/${item.id}` : undefined}
                    class:list={['tilt-card card group w-[280px] shrink-0 snap-start overflow-hidden !rounded-3xl p-0 sm:w-[320px]', !item.isReal && 'cursor-default']}
                  >
                    <div class="relative h-44 overflow-hidden">
                      {item.isReal && item.realImage ? (
                        <Image src={item.realImage} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" width={640} height={400} />
                      ) : (
                        <img src={item.fallbackImage} alt={item.title} loading="lazy" width="640" height="400" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                      )}
                      <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 rounded-full bg-paper/95 px-2.5 py-1 text-[11px] font-semibold text-ink">
                        <span class="h-1.5 w-1.5 rounded-full bg-accent-red" aria-hidden="true"></span>
                        {item.category}
                      </span>
                    </div>
                    <div class="flex flex-col p-5">
                      <p class="text-sm font-semibold leading-snug text-ink transition-colors group-hover:text-accent">{item.title}</p>
                      <p class="mt-2 line-clamp-2 text-xs leading-relaxed text-ink-dim">{item.excerpt}</p>
                      <p class="mt-3 text-xs text-ink-dim">{item.dateLabel} &middot; {item.readMinutes} min read</p>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>
        </Container>
      </section>
    )
  }

  <CTABand
    title="Have something you'd like us to build?"
    subtitle="Tell us what you need and we'll scope it, price it, and start within two weeks."
  />
</BaseLayout>

<script>
  function initMoreCarousel() {
    const track = document.querySelector<HTMLElement>('[data-more-track]');
    if (!track || track.dataset.bound) return;
    track.dataset.bound = '1';

    const prev = document.querySelector<HTMLButtonElement>('[data-more-prev]');
    const next = document.querySelector<HTMLButtonElement>('[data-more-next]');
    const step = () => (track.firstElementChild as HTMLElement | null)?.getBoundingClientRect().width ?? 300;

    prev?.addEventListener('click', () => track.scrollBy({ left: -(step() + 20), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: step() + 20, behavior: 'smooth' }));
  }

  initMoreCarousel();
  document.addEventListener('astro:page-load', initMoreCarousel);
</script>
