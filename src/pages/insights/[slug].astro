---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, related: posts.filter((p) => p.id !== post.id).slice(0, 3) },
  }));
}

const { post, related } = Astro.props;
const { Content } = await render(post);
const { data } = post;

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));
const formattedDate = data.publishDate.toLocaleDateString('en-MY', { year: 'numeric', month: 'long', day: 'numeric' });

const allPosts = await getCollection('posts', ({ data: d }) => !d.draft);
const categories = [...new Set(allPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout
  title={`${data.title}: WSS DevLabs Insights`}
  description={data.description}
  path={`/insights/${post.id}`}
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line bg-paper-dim py-8 text-center">
    <div class="dot-pattern absolute inset-0 opacity-50" aria-hidden="true" />
    <Container class="relative">
      <h1 class="sr-only">Blog Details</h1>
      <p class="text-3xl font-bold text-ink">Blog Details</p>
    </Container>
  </section>


  <!-- Article + Sidebar -->
  <section class="border-b border-line">
    <Container class="py-10">
      <!-- Wide hero image -->
      <div class="overflow-hidden rounded-2xl">
        <img
          src={typeof data.coverImage === 'string' ? data.coverImage : data.coverImage?.src ?? `https://picsum.photos/seed/blog-${post.id}/1200/500`}
          alt={data.title}
          class="h-56 w-full object-cover sm:h-72 md:h-96"
          loading="eager"
          width="1200"
          height="500"
        />
      </div>

      <!-- Meta row -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-accent px-3 py-1 text-xs font-bold text-white">{data.tags[0] ?? 'Insight'}</span>
        <span class="text-xs text-ink-dim">{formattedDate}</span>
        <span class="text-xs text-ink-dim">{readingMinutes} min read</span>
      </div>
      <h2 class="mt-3 text-2xl font-bold leading-snug tracking-tight text-ink md:text-3xl">{data.title}</h2>
      <div class="mt-2 flex items-center gap-2">
        <div class="h-7 w-7 overflow-hidden rounded-full bg-accent/20">
          <img src={`https://picsum.photos/seed/${data.author}/56/56`} alt={data.author} class="h-full w-full object-cover" loading="lazy" width="56" height="56" />
        </div>
        <span class="text-xs font-semibold text-ink">{data.author}</span>
      </div>

      <!-- Content + Sidebar -->
      <div class="mt-8 grid gap-8 lg:grid-cols-3">
        <!-- Main article -->
        <div class="relative lg:col-span-2">
          <!-- Share icons -->
          <div class="absolute -left-10 top-0 hidden flex-col gap-3 xl:flex">
            <a href={`https://twitter.com/intent/tweet?url=https://wssdevlabs.com/insights/${post.id}&text=${encodeURIComponent(data.title)}`} target="_blank" rel="noopener" aria-label="Share on X" class="flex h-8 w-8 items-center justify-center rounded-full border border-line bg-paper text-ink-dim transition-colors hover:border-accent hover:text-accent">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.254 5.622 5.91-5.622z"/></svg>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=https://wssdevlabs.com/insights/${post.id}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn" class="flex h-8 w-8 items-center justify-center rounded-full border border-line bg-paper text-ink-dim transition-colors hover:border-accent hover:text-accent">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=https://wssdevlabs.com/insights/${post.id}`} target="_blank" rel="noopener" aria-label="Share on Facebook" class="flex h-8 w-8 items-center justify-center rounded-full border border-line bg-paper text-ink-dim transition-colors hover:border-accent hover:text-accent">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>

          <!-- Dropcap content -->
          <div class="prose prose-neutral max-w-none text-sm leading-relaxed [&>p:first-of-type::first-letter]:float-left [&>p:first-of-type::first-letter]:mr-2 [&>p:first-of-type::first-letter]:mt-1 [&>p:first-of-type::first-letter]:text-5xl [&>p:first-of-type::first-letter]:font-black [&>p:first-of-type::first-letter]:leading-none [&>p:first-of-type::first-letter]:text-accent">
            <Content />
          </div>

          <!-- Author bio -->
          <div class="mt-8 flex items-center gap-4 rounded-2xl border border-line bg-paper-dim p-5">
            <div class="h-14 w-14 shrink-0 overflow-hidden rounded-full">
              <img src={`https://picsum.photos/seed/${data.author}/100/100`} alt={data.author} class="h-full w-full object-cover" loading="lazy" width="100" height="100" />
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-ink-dim">Author</p>
              <p class="mt-0.5 text-sm font-bold text-ink">{data.author}</p>
              <p class="mt-0.5 text-xs text-ink-dim">Engineering contributor at WSS DevLabs. Writing about software, product, and startups in Southeast Asia.</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-5">
          <!-- Filter by Categories -->
          <div class="rounded-2xl border border-line bg-paper p-5">
            <h3 class="text-sm font-bold text-ink">Filter by Categories</h3>
            <ul class="mt-3 space-y-1.5">
              <li>
                <a href="/insights" class="flex items-center justify-between rounded-lg bg-accent px-3 py-2 text-xs font-semibold text-white">
                  All Posts
                  <span class="rounded-full bg-white/20 px-2 py-0.5 text-[10px]">{allPosts.length}</span>
                </a>
              </li>
              {categories.map((cat) => {
                const count = allPosts.filter((p) => p.data.tags.includes(cat)).length;
                return (
                  <li>
                    <a href={`/insights?category=${encodeURIComponent(cat)}`} class="flex items-center justify-between rounded-lg px-3 py-2 text-xs font-semibold text-ink-dim transition-colors hover:bg-paper-dim hover:text-ink">
                      {cat}
                      <span class="rounded-full border border-line px-2 py-0.5 text-[10px]">{count}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- Table of Contents placeholder -->
          <div class="rounded-2xl border border-line bg-paper p-5">
            <h3 class="text-sm font-bold text-ink">Table of Content</h3>
            <nav id="toc-sidebar" class="mt-3 space-y-1.5 text-xs text-ink-dim">
              <p class="italic text-ink-dim/60">Generated from article headings</p>
            </nav>
          </div>

          <!-- CTA card -->
          <div class="rounded-2xl bg-ink p-5">
            <Eyebrow label="Work with Us" class="[&>*]:!text-white/50 [&>*:first-child]:!bg-accent" />
            <h4 class="mt-3 text-base font-bold text-white">Ready to Build Something Real?</h4>
            <p class="mt-2 text-xs leading-relaxed text-white/60">Tell us what you need and we will scope it, price it, and start within two weeks.</p>
            <a href="/contact" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-accent py-3 text-xs font-bold text-white transition-colors hover:bg-accent-dim">
              Start a Project
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Related Posts -->
  {related.length > 0 && (
    <section class="border-b border-line bg-paper-dim">
      <Container class="py-10">
        <div class="flex items-center justify-between">
          <div>
            <Eyebrow label="Related Blogs" />
            <h2 class="mt-2 text-2xl font-bold text-ink">Related Blog Posts</h2>
          </div>
          <a href="/insights" class="shrink-0 rounded-full border border-line px-4 py-2 text-xs font-semibold text-ink-dim transition-colors hover:border-accent hover:text-accent">
            View All
          </a>
        </div>
        <div class="mt-6 grid gap-5 sm:grid-cols-3">
          {related.map((p) => {
            const imgSrc = typeof p.data.coverImage === 'string' ? p.data.coverImage : p.data.coverImage?.src ?? `https://picsum.photos/seed/blog-${p.id}/600/400`;
            return (
              <a href={`/insights/${p.id}`} class="group block overflow-hidden rounded-2xl border border-line bg-paper shadow-sm transition-shadow hover:shadow-md">
                <div class="relative aspect-video overflow-hidden">
                  <img src={imgSrc} alt={p.data.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" width="600" height="400" />
                  <span class="absolute bottom-2 left-2 rounded-full bg-accent px-2.5 py-1 text-[10px] font-bold text-white">{p.data.tags[0] ?? 'Insight'}</span>
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-bold leading-snug text-ink transition-colors group-hover:text-accent">{p.data.title}</h3>
                  <p class="mt-2 line-clamp-2 text-xs text-ink-dim">{p.data.description}</p>
                  <p class="mt-2 text-[10px] text-ink-dim">{p.data.publishDate.toLocaleDateString('en-MY', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                </div>
              </a>
            );
          })}
        </div>
      </Container>
    </section>
  )}


</BaseLayout>

<script>
  const headings = document.querySelectorAll('.prose h2, .prose h3');
  const toc = document.getElementById('toc-sidebar');
  if (toc && headings.length > 0) {
    toc.innerHTML = '';
    headings.forEach((h, i) => {
      if (!h.id) { h.id = `heading-${i}`; }
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      a.className = `block py-1 text-xs ${h.tagName === 'H2' ? 'text-ink font-semibold' : 'pl-3 text-ink-dim'} hover:text-accent transition-colors`;
      toc.appendChild(a);
    });
  }
</script>
