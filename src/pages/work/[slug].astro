---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: {
      project,
      others: projects.filter((p) => p.id !== project.id).slice(0, 2),
    },
  }));
}

const { project, others } = Astro.props;
const { Content } = await render(project);
const { data } = project;

const firstLetter = (data.summary ?? data.headlineResult ?? 'W').charAt(0).toUpperCase();
---

<BaseLayout
  title={`${data.title}: WSS DevLabs`}
  description={data.summary ?? data.headlineResult}
  path={`/work/${project.id}`}
>

  <!-- Hero image -->
  <div class="border-b border-line bg-paper">
    <Container class="py-8">
      <div class="relative overflow-hidden rounded-2xl">
        <Image
          src={data.heroImage}
          alt={data.title}
          class="h-80 w-full object-cover sm:h-[28rem]"
          width={1200}
          height={600}
        />
        <div class="absolute inset-0 flex items-center justify-center">
          <button
            type="button"
            aria-label="Play video"
            class="flex h-16 w-16 items-center justify-center rounded-full bg-white/90 shadow-xl backdrop-blur-sm transition-transform hover:scale-110"
          >
            <svg class="ml-1 h-6 w-6 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
          </button>
        </div>
      </div>
    </Container>
  </div>

  <!-- Content + sidebar -->
  <section class="border-b border-line">
    <Container class="py-10">
      <div class="grid gap-10 lg:grid-cols-3">
        <!-- Main -->
        <div class="lg:col-span-2">
          <h1 class="text-2xl font-bold tracking-tight text-ink md:text-3xl">{data.title}</h1>
          <div class="mt-5 flex items-start gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-accent text-xl font-black text-white">
              {firstLetter}
            </span>
            <p class="flex-1 text-sm leading-relaxed text-ink-dim">{data.summary ?? data.headlineResult}</p>
          </div>
          <div class="prose prose-neutral mt-8 max-w-none">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside>
          <div class="sticky top-28 overflow-hidden rounded-2xl bg-ink text-white">
            {[
              { label: 'Project Category', value: data.category },
              { label: 'Client', value: data.client },
              { label: 'Duration', value: data.timeline },
              { label: 'Industry', value: data.industry },
            ].map((item) => (
              <div class="border-b border-white/10 px-6 py-5 last:border-0">
                <p class="text-[10px] font-bold uppercase tracking-widest text-white/40">{item.label}:</p>
                <p class="mt-1 text-sm font-semibold text-white">{item.value}</p>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- The Challenge -->
  <section class="border-b border-line bg-paper-dim">
    <Container class="max-w-4xl py-10">
      <h2 class="text-2xl font-bold text-ink">The Challenge</h2>
      <p class="mt-4 text-sm leading-relaxed text-ink-dim">
        Every project starts with a real business problem. For {data.client}, the challenge was clear: {data.headlineResult}. Our job was to understand the root cause, design the right solution, and execute with precision, with no fluff and no over-engineering.
      </p>
    </Container>
  </section>

  <!-- Solution + gallery -->
  <section class="border-b border-line">
    <Container class="max-w-4xl py-10">
      <h2 class="text-2xl font-bold text-ink">The Solution</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {data.services.map((service) => (
          <li class="flex items-start gap-3 text-sm text-ink-dim">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            {service}
          </li>
        ))}
      </ul>
      {data.gallery.length >= 2 && (
        <div class="mt-10 grid grid-cols-2 gap-4">
          {data.gallery.slice(0, 2).map((img) => (
            <div class="overflow-hidden rounded-2xl">
              <Image src={img} alt="" class="h-52 w-full object-cover transition-transform duration-500 hover:scale-105" width={600} height={400} />
            </div>
          ))}
        </div>
      )}
    </Container>
  </section>

  <!-- Impact -->
  {data.results.length > 0 && (
    <section class="border-b border-line bg-paper-dim">
      <Container class="py-10">
        <Eyebrow label="The Impact" />
        <h2 class="mt-3 text-2xl font-bold text-ink">Results That Speak for Themselves</h2>
        <div class="mt-8 grid gap-5 sm:grid-cols-3">
          {data.results.map((result) => (
            <div class="rounded-2xl border border-line bg-paper p-6 text-center shadow-sm">
              <p class="text-4xl font-black text-accent">{result.value}</p>
              <p class="mt-2 text-sm text-ink-dim">{result.label}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- Testimonial -->
  {data.testimonial && (
    <section class="border-b border-line">
      <Container class="max-w-3xl py-10">
        <div class="rounded-2xl border border-line bg-paper-dim p-8 shadow-sm">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-5 w-5 text-accent-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" /></svg>
            ))}
          </div>
          <blockquote class="mt-4 text-lg font-medium italic text-ink leading-relaxed">
            "{data.testimonial.quote}"
          </blockquote>
          <p class="mt-4 text-sm text-ink-dim">{data.testimonial.author} &middot; {data.testimonial.role}</p>
        </div>
      </Container>
    </section>
  )}

  <!-- CTA band -->
  <section class="border-b border-line bg-accent">
    <Container class="py-10">
      <div class="grid gap-6 md:grid-cols-2 md:items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-white/60">Contact Us</p>
          <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">Need Expert Help with Your Next Project?</h2>
          <p class="mt-2 text-sm text-white/70">Our engineers are ready. Tell us what you're building.</p>
        </div>
        <div class="flex items-center gap-4 md:justify-end">
          <a href="/contact" class="rounded-full bg-white px-7 py-3 text-sm font-bold text-accent shadow-md transition-all hover:bg-white/90 hover:shadow-lg">
            Start a Project
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- View other projects -->
  {others.length > 0 && (
    <section class="border-b border-line">
      <Container class="py-10">
        <h2 class="text-xl font-bold text-ink">View Other Projects</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          {others.map((p) => (
            <a href={`/work/${p.id}`} class="tilt-card group overflow-hidden rounded-2xl border border-line bg-paper shadow-sm transition-all hover:border-accent/30 hover:shadow-md">
              <Image
                src={p.data.heroImage}
                alt={p.data.title}
                class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                width={600}
                height={350}
              />
              <div class="flex items-center justify-between p-5">
                <div>
                  <h3 class="text-sm font-bold text-ink transition-colors group-hover:text-accent">{p.data.title}</h3>
                  <p class="mt-1 text-xs text-ink-dim">{p.data.category}</p>
                </div>
                <span class="flex h-9 w-9 items-center justify-center rounded-full bg-accent text-white">
                  <svg class="h-4 w-4 -rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

</BaseLayout>
