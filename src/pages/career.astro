---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { JOB_OPENINGS } from '../data/career';

const openings = JOB_OPENINGS;
---

<BaseLayout
  title="Career: WSS DevLabs"
  description="Join WSS DevLabs as a freelance or part-time contributor. We are looking for engineers, designers, and marketers who take craft seriously."
  path="/career"
>

  <!-- Job Openings -->
  <section id="openings" class="border-b border-line">
    <Container class="py-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">Current Openings</h2>
      </div>
      <div class="mt-8 space-y-3">
        {openings.map((job, i) => (
          <details class="group overflow-hidden rounded-2xl border border-line bg-paper shadow-sm" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5">
              <div class="min-w-0">
                <h3 class="text-sm font-bold text-ink">{job.title}</h3>
                <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1">
                  <span class="text-xs text-ink-dim">Experience: {job.experience}</span>
                  <span class="text-xs text-ink-dim">No of Opening: {job.positions}</span>
                  <span class="text-xs text-ink-dim">Job Type: {job.type}</span>
                </div>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <span class="hidden items-center gap-1 rounded-full border border-line px-4 py-2 text-xs font-semibold text-ink sm:flex">
                  Details
                  <svg class="h-3 w-3 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                </span>
                <a
                  href={`mailto:hello@wssdevlabs.com?subject=Application: ${job.title}`}
                  class="rounded-full bg-accent-red px-4 py-2 text-xs font-bold text-white transition-colors hover:bg-accent-red-dim"
                  data-apply-link
                >
                  Apply Now
                </a>
              </div>
            </summary>
            <div class="border-t border-line px-6 pb-6 pt-4">
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-widest text-ink">Roles and Responsibilities</h4>
                  <ul class="mt-3 space-y-2">
                    {job.responsibilities.map((r) => (
                      <li class="flex items-start gap-2 text-xs text-ink-dim">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                        {r}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-widest text-ink">Skills and Qualification</h4>
                  <ul class="mt-3 space-y-2">
                    {job.skills.map((s) => (
                      <li class="flex items-start gap-2 text-xs text-ink-dim">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-blue" />
                        {s}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>
    </Container>
  </section>


</BaseLayout>

<script>
  document.querySelectorAll('[data-apply-link]').forEach((link) => {
    link.addEventListener('click', (e) => e.stopPropagation());
  });
</script>
