---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { JOB_OPENINGS, BENEFITS } from '../data/career';

const openings = JOB_OPENINGS;
---

<BaseLayout
  title="Career: WSS DevLabs"
  description="Join WSS DevLabs as a freelance or part-time contributor. We are looking for engineers, designers, and marketers who take craft seriously."
  path="/career"
>
  <!-- Join our team: opening teasers + quick-apply form -->
  <Section rule>
    <Container>
      <div class="mx-auto max-w-xl text-center">
        <p class="mono-label justify-center text-accent-red">Vacancy / Career</p>
        <h1 class="h-section mt-3" data-split>Join Our Team!</h1>
        <p class="mt-4 text-sm leading-relaxed text-ink-dim">
          Freelance and part-time roles for engineers, designers, and marketers who take craft
          seriously. See what's open below, or send a general application.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-[2fr_1fr]" data-stagger>
        <!-- Opening teaser cards -->
        <div class="grid gap-5 sm:grid-cols-2">
          {
            openings.map((job) => (
              <div data-stagger-child class="tilt-card card flex flex-col p-6">
                <span class="mono-label !text-[0.6rem] text-ink-dim">{job.type}</span>
                <h3 class="mt-2 text-base font-bold tracking-tight text-ink">{job.title}</h3>
                <p class="mt-2 flex-1 text-xs leading-relaxed text-ink-dim">
                  {job.experience} &middot; {job.positions}
                </p>
                <a
                  href={`#job-${job.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
                  class="mt-5 inline-flex items-center justify-center rounded-full bg-accent-red px-5 py-2.5 text-xs font-bold text-white transition-colors hover:bg-accent-red-dim"
                >
                  Apply Now
                </a>
              </div>
            ))
          }
        </div>

        <!-- Quick apply form -->
        <div data-stagger-child class="panel-charcoal flex flex-col overflow-hidden">
          <div class="bg-ink px-6 py-4">
            <h2 class="text-center text-sm font-bold uppercase tracking-wide text-white">Join Our Team</h2>
          </div>
          <form id="quick-apply-form" class="flex flex-1 flex-col gap-3 p-6" onsubmit="return false;">
            <input
              type="text"
              id="qa-name"
              placeholder="Your Name"
              required
              class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:border-accent focus:outline-none"
            />
            <input
              type="email"
              id="qa-email"
              placeholder="Your Email"
              required
              class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:border-accent focus:outline-none"
            />
            <select
              id="qa-position"
              class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white focus:border-accent focus:outline-none"
            >
              <option value="" class="text-ink">Your Position</option>
              {openings.map((job) => (
                <option value={job.title} class="text-ink">{job.title}</option>
              ))}
            </select>
            <textarea
              id="qa-message"
              rows="4"
              placeholder="Enter your message"
              class="w-full flex-1 resize-none rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:border-accent focus:outline-none"
            />
            <button
              type="submit"
              id="qa-submit"
              class="mt-1 inline-flex items-center justify-center rounded-full bg-accent-red px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-accent-red-dim"
            >
              Send Application
            </button>
          </form>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Benefits -->
  <Section rule class="bg-paper-dim">
    <Container>
      <div class="mx-auto max-w-xl text-center">
        <p class="mono-label justify-center text-accent-red">Our Benefits</p>
        <h2 class="h-section mt-3" data-split>Why the team enjoys working here</h2>
      </div>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {
          BENEFITS.map((b) => (
            <div data-stagger-child class="flex flex-col items-center text-center">
              <span class="flex h-14 w-14 items-center justify-center rounded-full bg-charcoal text-white">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d={b.icon} />
                </svg>
              </span>
              <p class="mt-4 font-semibold tracking-tight text-ink">{b.title}</p>
              <p class="mt-1.5 text-xs leading-relaxed text-ink-dim">{b.desc}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </Section>

  <!-- Full job details -->
  <section id="openings" class="border-b border-line">
    <Container class="py-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">Current Openings</h2>
      </div>
      <div class="mt-8 space-y-3">
        {openings.map((job, i) => (
          <details
            id={`job-${job.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            class="group overflow-hidden rounded-2xl border border-line bg-paper shadow-sm"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5">
              <div class="min-w-0">
                <h3 class="text-sm font-bold text-ink">{job.title}</h3>
                <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1">
                  <span class="text-xs text-ink-dim">Experience: {job.experience}</span>
                  <span class="text-xs text-ink-dim">No of Opening: {job.positions}</span>
                  <span class="text-xs text-ink-dim">Job Type: {job.type}</span>
                </div>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <span class="hidden items-center gap-1 rounded-full border border-line px-4 py-2 text-xs font-semibold text-ink sm:flex">
                  Details
                  <svg class="h-3 w-3 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                </span>
                <a
                  href={`mailto:hello@wssdevlabs.com?subject=Application: ${job.title}`}
                  class="rounded-full bg-accent-red px-4 py-2 text-xs font-bold text-white transition-colors hover:bg-accent-red-dim"
                  data-apply-link
                >
                  Apply Now
                </a>
              </div>
            </summary>
            <div class="border-t border-line px-6 pb-6 pt-4">
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-widest text-ink">Roles and Responsibilities</h4>
                  <ul class="mt-3 space-y-2">
                    {job.responsibilities.map((r) => (
                      <li class="flex items-start gap-2 text-xs text-ink-dim">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                        {r}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-widest text-ink">Skills and Qualification</h4>
                  <ul class="mt-3 space-y-2">
                    {job.skills.map((s) => (
                      <li class="flex items-start gap-2 text-xs text-ink-dim">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-blue" />
                        {s}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>
    </Container>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('[data-apply-link]').forEach((link) => {
    link.addEventListener('click', (e) => e.stopPropagation());
  });

  const form = document.getElementById('quick-apply-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('qa-name') as HTMLInputElement).value;
    const email = (document.getElementById('qa-email') as HTMLInputElement).value;
    const position = (document.getElementById('qa-position') as HTMLSelectElement).value;
    const message = (document.getElementById('qa-message') as HTMLTextAreaElement).value;
    const subject = encodeURIComponent(`Application: ${position || 'General enquiry'}`);
    const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\nPosition: ${position}\n\nMessage:\n${message}`);
    window.location.href = `mailto:hello@wssdevlabs.com?subject=${subject}&body=${body}`;
  });
</script>
