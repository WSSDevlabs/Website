---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import Differentiator from '../../components/sections/Differentiator.astro';
import QuoteForm from '../../components/sections/QuoteForm.astro';
import { PRICING_TIERS } from '../../data/pricing';

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', siteUrl).toString() },
    { '@type': 'ListItem', position: 2, name: 'Services', item: new URL('/services', siteUrl).toString() }
  ]
};
---

<BaseLayout
  title="Services: WSS DevLabs"
  description="Web development, mobile apps, custom systems, AI, branding, marketing, student projects, grants, and business launches. Whatever the digital need, one team handles it."
  path="/services"
  schema={schema}
>

  <ServicesGrid />

  <!-- Pricing at a glance -->
  <Section rule class="bg-paper-dim">
    <Container>
      <div class="mx-auto max-w-xl text-center">
        <h2 class="h-section" data-split>Plans that scale with you</h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-3" data-stagger>
        {
          PRICING_TIERS.map((tier) => (
            <div
              data-stagger-child
              class:list={[
                'relative flex flex-col rounded-3xl bg-paper p-7 transition-all duration-300 [transition-timing-function:var(--ease-out-expo)] hover:-translate-y-1',
                tier.highlight ? 'ring-2 ring-accent shadow-card-hover' : 'ring-1 ring-line'
              ]}
            >
              {tier.highlight && (
                <span class="absolute -right-3 -top-3 flex h-10 w-10 items-center justify-center rounded-full bg-accent text-white shadow-card">
                  <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V3a.75.75 0 0 1 .75-.75A2.25 2.25 0 0 1 16.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H6.633" />
                  </svg>
                </span>
              )}

              <h3 class="text-lg font-bold text-ink">{tier.name}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-dim">{tier.description}</p>

              <div
                class:list={[
                  'mt-6 flex h-16 items-center justify-center rounded-2xl px-4',
                  tier.highlight ? 'bg-accent' : 'bg-charcoal'
                ]}
              >
                <p class="num-feature text-center text-lg leading-tight text-white">{tier.price}</p>
              </div>

              <p class="mono-label mt-6 text-ink-dim">What's included</p>
              <ul class="mt-4 flex-1 space-y-2.5">
                {tier.features.slice(0, 6).map((feature) => (
                  <li class="flex items-start gap-2.5 text-sm text-ink-dim">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={tier.ctaHref}
                class="mt-6 inline-flex items-center justify-center gap-1.5 text-sm font-semibold text-accent hover:underline"
              >
                {tier.cta}
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-ink-dim">
        See the full feature breakdown on our{' '}
        <a href="/pricing" class="font-semibold text-accent hover:underline">Pricing page</a>
        {' '}or{' '}
        <a href="/contact" class="font-semibold text-accent hover:underline">request an accurate quote</a>.
      </p>
    </Container>
  </Section>

  <Differentiator />
  <QuoteForm />
</BaseLayout>
