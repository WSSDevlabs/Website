    'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'mobile-app-development': [
    'https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1512428813834-c702c7702b78?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1551650975-87deedd944c3?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'custom-systems': [
    'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'ai-development': [
    'https://images.unsplash.com/photo-1555255707-c07966088b7b?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1526378800951-0eb6b1e7e9e2?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'ui-ux-design': [
    'https://images.unsplash.com/photo-1587440871875-191322ee64b0?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1559028006-448665bd7c7f?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1581291518857-4e27b48ff24e?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'maintenance-support': [
    'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1580894742597-87bc8789db3d?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'digital-marketing': [
    'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1533750349088-cd871a92f312?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1432888622747-4eb9a8efeb07?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'business-growth': [
    'https://images.unsplash.com/photo-1553877522-43269d4ea984?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'branding-services': [
    'https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'product-photoshoot-marketing': [
    'https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1533900298318-6b8da08a523e?auto=format&fit=crop&w=600&h=400&q=80',
  ],
  'media-creation': [
    'https://images.unsplash.com/photo-1492619375914-88005aa9e8fb?auto=format&fit=crop&w=1200&h=600&q=80',
    'https://images.unsplash.com/photo-1601506521937-0121a7fc2a6b?auto=format&fit=crop&w=600&h=400&q=80',
    'https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?auto=format&fit=crop&w=600&h=400&q=80',
  ],
};
const [heroImg, imgA, imgB] = serviceImages[service.slug] ?? serviceImages['web-development'];

const testimonials = [
  {
    quote: 'WSS DevLabs built our platform from scratch in 8 weeks. The code quality and attention to performance was well beyond what I expected from a studio this lean.',
    author: 'Ahmad Razif',
    role: 'Founder',
    company: 'Nexora Sdn Bhd',
    rating: 5,
  },
  {
    quote: 'They handled our migration with zero downtime and delivered improvements we started seeing within the first month.',
    author: 'Priya Nair',
    role: 'Head of Digital',
    company: 'RetailPlus MY',
    rating: 5,
  },
  {
    quote: 'The solution they built cut our response time by 70%. Solid engineers who actually understand product requirements.',
    author: 'Marcus Tan',
    role: 'CEO',
    company: 'GrowthStack',
    rating: 5,
  },
];

const toneAccent: Record<string, string> = {
  red:    'bg-accent',
  blue:   'bg-accent-blue',
  yellow: 'bg-accent-yellow',
  green:  'bg-accent-green',
  neutral:'bg-ink-dim',
};
const toneText: Record<string, string> = {
  red:    'text-accent',
  blue:   'text-accent-blue',
  yellow: 'text-accent-yellow',
  green:  'text-accent-green',
  neutral:'text-ink-dim',
};
---

<ServiceLayout
  title={`${service.title} — WSS DevLabs`}
  description={service.shortDescription}
  path={`/services/${service.slug}`}
  serviceName={service.title}
>
  <!-- ── Centered page hero ─────────────────────────────────── -->
  <section class="relative overflow-hidden border-b border-line bg-paper-dim py-8 text-center">
    <div class="dot-pattern absolute inset-0 opacity-50" aria-hidden="true" />
    <Container class="relative">
      <nav aria-label="Breadcrumb" class="mb-5 flex justify-center">
        <ol class="flex items-center gap-2 text-xs text-ink-dim">
          <li><a href="/" class="transition-colors hover:text-accent">Home</a></li>
          <li class="flex items-center gap-2">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
            <a href="/services" class="transition-colors hover:text-accent">Services</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
            <span class="font-medium text-ink">Service Details</span>
          </li>
        </ol>
      </nav>
      <h1 class="text-5xl font-bold tracking-tight text-ink md:text-6xl">Service Details</h1>
      <p class="mt-3 text-base text-ink-dim">{service.title}</p>
    </Container>
  </section>

  <!-- ── Hero image ────────────────────────────────────────── -->
  <div class="border-b border-line bg-paper">
    <Container class="py-8">
      <div class="overflow-hidden rounded-2xl">
        <img
          src={heroImg}
          alt={service.title}
          class="h-72 w-full object-cover sm:h-96"
          loading="eager"
          width="1200"
          height="600"
        />
      </div>
    </Container>
  </div>

  <!-- ── About section ─────────────────────────────────────── -->
  <Section class="border-b border-line">
    <Container class="max-w-4xl">
      <h2 class="text-2xl font-bold tracking-tight text-ink md:text-3xl">
        About {service.title} Services
      </h2>

      <!-- Dropcap paragraph -->
      <div class="mt-6 flex items-start gap-4">
        <span class:list={[
          'flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-xl font-black text-white',
          toneAccent[tone],
        ]}>
          {service.valueProp.charAt(0)}
        </span>
        <p class="flex-1 text-sm leading-relaxed text-ink-dim">{service.valueProp}</p>
      </div>

      <p class="mt-5 text-sm leading-relaxed text-ink-dim">{service.problem}</p>
    </Container>
  </Section>

  <!-- ── Services Include (deliverables) ───────────────────── -->
  <Section class="border-b border-line">
    <Container class="max-w-4xl">
      <h3 class="inline-flex items-center gap-2 text-xl font-bold text-ink">
        Services Include:
        <span class:list={['h-0.5 w-12 rounded-full', toneAccent[tone]]} aria-hidden="true" />
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-ink-dim">{service.shortDescription}</p>

      <!-- Checklist grid -->
      <ul class="mt-6 grid gap-x-8 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          service.deliverables.map((item) => (
            <li class="flex items-start gap-2.5 text-sm text-ink-dim">
              <svg
                class:list={['mt-0.5 h-4 w-4 shrink-0', toneText[tone]]}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>

      <!-- Two supporting images -->
      <div class="mt-10 grid grid-cols-2 gap-4">
        <div class="overflow-hidden rounded-2xl">
          <img
            src={imgA}
            alt=""
            class="h-48 w-full object-cover sm:h-56"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
        <div class="overflow-hidden rounded-2xl">
          <img
            src={imgB}
            alt=""
            class="h-48 w-full object-cover sm:h-56"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- ── Our Expertise (approach steps as numbered cards) ───── -->
  <Section class="border-b border-line">
    <Container class="max-w-4xl">
      <h2 class="text-2xl font-bold tracking-tight text-ink md:text-3xl">
        Our Expertise In {service.title}
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-ink-dim max-w-2xl">
        Our structured approach ensures every project delivers real outcomes — on time, on scope, and built to last.
      </p>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          service.approach.map((step, i) => {
            const [head, ...rest] = step.split(':');
            const title = rest.length ? head.trim() : step;
            const desc  = rest.length ? rest.join(':').trim() : '';

            return (
              <div class="relative rounded-2xl border border-line bg-paper-dim p-5 transition-all hover:border-accent/30 hover:shadow-md">
                <span class:list={[
                  'flex h-10 w-10 items-center justify-center rounded-xl text-sm font-black text-white',
                  toneAccent[tone],
                ]}>
                  0{i + 1}
                </span>
                <h4 class="mt-4 text-sm font-bold text-ink">{title}</h4>
                {desc && <p class="mt-1.5 text-xs leading-relaxed text-ink-dim">{desc}</p>}
              </div>
            );
          })
        }
      </div>
    </Container>
  </Section>

  <!-- ── Services Benefits (tools / stack) ─────────────────── -->
  <Section class="border-b border-line">
    <Container class="max-w-4xl">
      <h3 class="inline-flex items-center gap-2 text-xl font-bold text-ink">
        Services Benefits:
        <span class:list={['h-0.5 w-12 rounded-full', toneAccent[tone]]} aria-hidden="true" />
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-ink-dim max-w-2xl">
        We use proven, production-grade tools and methodologies to deliver outcomes you can measure — not just deliverables you can check off.
      </p>

      <ul class="mt-6 space-y-3">
        {
          service.tools.map((tool) => (
            <li class="flex items-center gap-3 text-sm text-ink-dim">
              <span class:list={['h-2 w-2 shrink-0 rounded-full', toneAccent[tone]]} aria-hidden="true" />
              {tool}
            </li>
          ))
        }
        {
          service.pricingFrom && (
            <li class="mt-4 flex items-center gap-3 text-sm font-semibold text-ink">
              <span class:list={['h-2 w-2 shrink-0 rounded-full', toneAccent[tone]]} aria-hidden="true" />
              Pricing from {service.pricingFrom}
            </li>
          )
        }
      </ul>
    </Container>
  </Section>

  <!-- ── Testimonials ───────────────────────────────────────── -->
  <Testimonials testimonials={testimonials} />

  <!-- ── Quote Form ────────────────────────────────────────── -->
  <QuoteForm />

  <!-- ── Newsletter ────────────────────────────────────────── -->
  <NewsletterBand />
</ServiceLayout>
