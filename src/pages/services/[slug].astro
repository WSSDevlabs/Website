---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import QuoteForm from '../../components/sections/QuoteForm.astro';
import NewsletterBand from '../../components/sections/NewsletterBand.astro';
import { SERVICES } from '../../data/services';
import { GROUP_TONE } from '../../lib/tone';

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const tone = GROUP_TONE[service.group];

const serviceImages: Record<string, [string, string, string]> = {
  'web-development': [
