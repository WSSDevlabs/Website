---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { SITE } from '../data/site';

const lastUpdated = new Date('2026-01-01');
---

<BaseLayout
  title="Cookie Policy"
  description="How WSS DevLabs uses cookies and similar technologies on this website."
  path="/cookies"
>
  <Section>
    <Container class="prose prose-neutral max-w-3xl">
      <h1>Cookie Policy</h1>
      <p>
        Last updated: {
          lastUpdated.toLocaleDateString('en-MY', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })
        }
      </p>

      <h2>1. What we use</h2>
      <p>
        This site uses Cloudflare Web Analytics, a privacy-friendly analytics service that does not
        use tracking cookies and does not collect personally identifiable information.
      </p>

      <h2>2. Local storage</h2>
      <p>
        We use your browser's local storage (not a cookie) to remember that you've seen the cookie
        notice, so it isn't shown again on every visit.
      </p>

      <h2>3. Third-party services</h2>
      <p>
        Our contact form is processed by Web3Forms. Refer to their privacy policy for details on how
        they handle submitted data.
      </p>

      <h2>4. Your choices</h2>
      <p>
        You can clear your browser's local storage at any time to reset cookie notice preferences.
        Disabling analytics scripts in your browser will not affect site functionality.
      </p>

      <h2>5. Contact</h2>
      <p>Questions about this policy can be sent to {SITE.email || 'our contact email'}.</p>
    </Container>
  </Section>
</BaseLayout>
