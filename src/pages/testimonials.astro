---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import { TESTIMONIALS } from '../data/testimonials';

const extraTestimonials = [
  { quote: 'WSS DevLabs built our platform from scratch in 8 weeks. The code quality and attention to performance was well beyond what I expected from a studio this lean.', author: 'Ahmad Razif', role: 'Founder', company: 'Nexora Sdn Bhd', rating: 5 },
  { quote: 'They handled our migration with zero downtime and delivered improvements we started seeing within the first month. Professional, direct, and reliable.', author: 'Priya Nair', role: 'Head of Digital', company: 'RetailPlus MY', rating: 5 },
  { quote: 'The AI tool they built cut our response time by 70%. Solid engineers who actually understand product requirements and deliver without over-complicating things.', author: 'Marcus Tan', role: 'CEO', company: 'GrowthStack', rating: 5 },
  { quote: 'Our website went from a slow template to a Lighthouse 98 score in three weeks. The team communicates clearly and ships what they promise.', author: 'Dianne Russell', role: 'Owner', company: 'Architecture Studio', rating: 5 },
  { quote: 'We needed a custom CRM integrated with our ops tool. WSS DevLabs scoped it accurately, built it cleanly, and handed it over with full documentation.', author: 'Bessie Cooper', role: 'CEO', company: 'Car Rental App', rating: 5 },
  { quote: 'Very impressed with the speed of delivery. They built a React Native app for our logistics team in 10 weeks and it has been running in production with zero crashes.', author: 'Amelia Taylor', role: 'CFO', company: 'Finance App', rating: 5 },
  { quote: 'The branding and website redesign transformed how our clients perceive us. We are now winning pitches we previously lost on first impression alone.', author: 'Mia Anderson', role: 'Owner', company: 'Salon', rating: 5 },
  { quote: 'WSS DevLabs did not just build our site, they built a system. SEO structure, performance, CMS access, everything was thought through before a line of code was written.', author: 'Ava Miller', role: 'Owner', company: 'Flower Shop', rating: 5 },
  { quote: 'Our digital marketing ROI doubled in four months after WSS DevLabs took over our campaigns. Data-driven, transparent reporting and no excuses.', author: 'Charlotte Davis', role: 'Dentist', company: 'Dental Clinic', rating: 5 },
  { quote: 'Hands down the best engineering team I have worked with as a non-technical founder. They translated complex requirements into a clean, working product.', author: 'Evelyn Thomas', role: 'CEO', company: 'Digital Agency', rating: 5 },
  { quote: 'Our mobile app launched on time, on budget, and with better UX than we originally scoped. The team pushed back on bad ideas and replaced them with better ones.', author: 'Harper Martinez', role: 'Owner', company: 'Photo Studio', rating: 5 },
  { quote: 'The custom ERP system they built replaced three legacy tools. Training was smooth because the UI was intuitive from day one.', author: 'James Wilson', role: 'Operations Director', company: 'Manufacturing Co', rating: 5 },
];

const allTestimonials = TESTIMONIALS.length > 0 ? TESTIMONIALS : extraTestimonials;
---

<BaseLayout
  title="Testimonials: WSS DevLabs"
  description="Real feedback from founders, operators, and marketing leads who have worked with WSS DevLabs."
  path="/testimonials"
>
  <!-- Reviews carousel -->
  <section class="border-b border-line">
    <Container class="py-12 md:py-16">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-xl">
          <p class="mono-label text-ink-dim">What people say about us</p>
          <h1 class="h-display mt-3 !text-[clamp(2rem,1.3rem+2.6vw,3.2rem)]" data-split>Reviews from our clients</h1>
          <p class="mt-4 leading-relaxed text-ink-dim">
            Real feedback from founders, operators, and marketing leads who've worked with WSS
            DevLabs on real projects.
          </p>
        </div>
        <div class="flex shrink-0 gap-2">
          <button
            type="button"
            aria-label="Previous reviews"
            data-t-prev
            class="flex h-11 w-11 items-center justify-center rounded-full border border-line bg-paper text-ink shadow-card transition-colors hover:bg-ink hover:text-white"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            type="button"
            aria-label="Next reviews"
            data-t-next
            class="flex h-11 w-11 items-center justify-center rounded-full border border-line bg-paper text-ink shadow-card transition-colors hover:bg-ink hover:text-white"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>

      <div class="mt-12 mask-fade-x -mx-6 px-6 md:-mx-10 md:px-10">
        <div
          class="flex gap-6 overflow-x-auto pb-2 snap-x snap-mandatory [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          data-t-track
        >
          {
            allTestimonials.map((t, i) => (
              <div class="tilt-card card w-[300px] shrink-0 snap-start overflow-hidden !rounded-3xl p-0 sm:w-[340px]" data-reveal="tilt3d">
                <div class="relative h-56 overflow-hidden">
                  <img
                    src={`https://picsum.photos/seed/wss-review-${i}/500/400`}
                    alt={t.author}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    width="500"
                    height="400"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/10 to-transparent" aria-hidden="true"></div>
                  <div class="absolute left-4 top-4 flex gap-0.5">
                    {Array.from({ length: t.rating ?? 5 }).map(() => (
                      <svg class="h-3.5 w-3.5 text-accent-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" /></svg>
                    ))}
                  </div>
                  <p class="absolute bottom-4 left-4 right-4 font-semibold text-white">{t.author}</p>
                </div>
                <div class="flex flex-col p-6">
                  <p class="text-sm leading-relaxed text-ink-dim">&ldquo;{t.quote}&rdquo;</p>
                  <p class="mt-4 text-xs font-semibold text-ink-dim">{t.role}{t.company ? `, ${t.company}` : ''}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-4 border-t border-line pt-10 text-center">
        <a
          href="/contact"
          data-magnetic
          class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 text-sm font-semibold text-white shadow-[0_8px_20px_-8px_rgb(45_91_227/0.5)] transition-all hover:-translate-y-0.5 hover:bg-accent-dim"
        >
          Start a Project
        </a>
        <a
          href="mailto:hello@wssdevlabs.com?subject=Client review"
          class="inline-flex items-center gap-2 rounded-full border border-line bg-paper px-7 py-3.5 text-sm font-semibold text-ink shadow-card transition-all hover:-translate-y-0.5 hover:border-ink/25"
        >
          Leave a review
        </a>
      </div>
    </Container>
  </section>

  <QuoteForm />
</BaseLayout>

<script>
  function initTestimonialCarousel() {
    const track = document.querySelector<HTMLElement>('[data-t-track]');
    if (!track || track.dataset.bound) return;
    track.dataset.bound = '1';

    const prev = document.querySelector<HTMLButtonElement>('[data-t-prev]');
    const next = document.querySelector<HTMLButtonElement>('[data-t-next]');
    const step = () => (track.firstElementChild as HTMLElement | null)?.getBoundingClientRect().width ?? 320;

    prev?.addEventListener('click', () => track.scrollBy({ left: -(step() + 24), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: step() + 24, behavior: 'smooth' }));
  }

  initTestimonialCarousel();
  document.addEventListener('astro:page-load', initTestimonialCarousel);
</script>
