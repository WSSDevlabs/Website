---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import { TESTIMONIALS } from '../data/testimonials';

const extraTestimonials = [
  { quote: 'WSS DevLabs built our platform from scratch in 8 weeks. The code quality and attention to performance was well beyond what I expected from a studio this lean.', author: 'Ahmad Razif', role: 'Founder', company: 'Nexora Sdn Bhd', rating: 5 },
  { quote: 'They handled our migration with zero downtime and delivered improvements we started seeing within the first month. Professional, direct, and reliable.', author: 'Priya Nair', role: 'Head of Digital', company: 'RetailPlus MY', rating: 5 },
  { quote: 'The AI tool they built cut our response time by 70%. Solid engineers who actually understand product requirements and deliver without over-complicating things.', author: 'Marcus Tan', role: 'CEO', company: 'GrowthStack', rating: 5 },
  { quote: 'Our website went from a slow template to a Lighthouse 98 score in three weeks. The team communicates clearly and ships what they promise.', author: 'Dianne Russell', role: 'Owner', company: 'Architecture Studio', rating: 5 },
  { quote: 'We needed a custom CRM integrated with our ops tool. WSS DevLabs scoped it accurately, built it cleanly, and handed it over with full documentation.', author: 'Bessie Cooper', role: 'CEO', company: 'Car Rental App', rating: 5 },
  { quote: 'Very impressed with the speed of delivery. They built a React Native app for our logistics team in 10 weeks and it has been running in production with zero crashes.', author: 'Amelia Taylor', role: 'CFO', company: 'Finance App', rating: 5 },
  { quote: 'The branding and website redesign transformed how our clients perceive us. We are now winning pitches we previously lost on first impression alone.', author: 'Mia Anderson', role: 'Owner', company: 'Salon', rating: 5 },
  { quote: 'WSS DevLabs did not just build our site, they built a system. SEO structure, performance, CMS access, everything was thought through before a line of code was written.', author: 'Ava Miller', role: 'Owner', company: 'Flower Shop', rating: 5 },
  { quote: 'Our digital marketing ROI doubled in four months after WSS DevLabs took over our campaigns. Data-driven, transparent reporting and no excuses.', author: 'Charlotte Davis', role: 'Dentist', company: 'Dental Clinic', rating: 5 },
  { quote: 'Hands down the best engineering team I have worked with as a non-technical founder. They translated complex requirements into a clean, working product.', author: 'Evelyn Thomas', role: 'CEO', company: 'Digital Agency', rating: 5 },
  { quote: 'Our mobile app launched on time, on budget, and with better UX than we originally scoped. The team pushed back on bad ideas and replaced them with better ones.', author: 'Harper Martinez', role: 'Owner', company: 'Photo Studio', rating: 5 },
  { quote: 'The custom ERP system they built replaced three legacy tools. Training was smooth because the UI was intuitive from day one.', author: 'James Wilson', role: 'Operations Director', company: 'Manufacturing Co', rating: 5 },
];

const allTestimonials = TESTIMONIALS.length > 0 ? TESTIMONIALS : extraTestimonials;
const INITIAL_SHOW = 8;
---

<BaseLayout
  title="Testimonials: WSS DevLabs"
  description="Real feedback from founders, operators, and marketing leads who have worked with WSS DevLabs."
  path="/testimonials"
>

  <!-- Testimonials grid -->
  <section class="border-b border-line">
    <Container class="py-8">
      <div class="text-center">
        <Eyebrow label="Testimonials" class="justify-center" />
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
          Testimonials: Trusted<br />by Our Clients
        </h2>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2" id="testimonials-grid">
        {allTestimonials.map((t, i) => (
          <div
            data-t-card
            class:list={[
              'rounded-2xl border border-line bg-paper p-6 shadow-sm transition-shadow hover:shadow-md',
              i >= INITIAL_SHOW ? 'hidden' : '',
            ]}
          >
            <div class="flex items-center gap-2">
              <div class="flex gap-0.5">
                {Array.from({ length: t.rating ?? 5 }).map(() => (
                  <svg class="h-4 w-4 text-accent-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" /></svg>
                ))}
              </div>
              <span class="text-sm font-bold text-ink">{t.rating ?? 5}.0</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-dim">"{t.quote}"</p>
            <div class="mt-4 border-t border-line pt-4">
              <p class="text-sm font-bold text-ink">{t.author}</p>
              <p class="mt-0.5 text-xs text-ink-dim">{t.role}{t.company ? `, ${t.company}` : ''}</p>
            </div>
          </div>
        ))}
      </div>

      <div id="load-more-t-wrap" class="mt-8 text-center">
        <button
          id="load-more-t"
          type="button"
          class="inline-flex items-center gap-2 rounded-full bg-accent-blue px-8 py-3 text-sm font-semibold text-white shadow-md shadow-accent-blue/20 transition-colors hover:bg-accent-blue-dim"
        >
          Load More
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
        </button>
      </div>
    </Container>
  </section>

  <QuoteForm />


</BaseLayout>

<script>
  const btn = document.getElementById('load-more-t');
  const wrap = document.getElementById('load-more-t-wrap');
  if (btn && wrap) {
    const hidden = document.querySelectorAll('[data-t-card].hidden');
    if (hidden.length === 0) { wrap.style.display = 'none'; }
    btn.addEventListener('click', () => {
      hidden.forEach((card) => card.classList.remove('hidden'));
      wrap.style.display = 'none';
    });
  }
</script>
