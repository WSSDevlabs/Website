---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import FAQ from '../components/sections/FAQ.astro';
import CTABand from '../components/sections/CTABand.astro';

const categories = [
  { id: 'general', label: 'General Information' },
  { id: 'services', label: 'Services' },
  { id: 'process', label: 'Process' },
  { id: 'pricing', label: 'Pricing & Plans' },
  { id: 'technical', label: 'Technical' },
];

const allFaqs = [
  { cat: 'general', q: 'What does WSS DevLabs do?', a: 'We build custom websites, mobile apps, custom business systems (CMS/ERP), and AI-powered software for startups and growing companies, all engineered from scratch and not assembled from templates.' },
  { cat: 'general', q: 'Where are you based?', a: 'We are based in Kuala Lumpur, Malaysia, and work remotely with clients across Southeast Asia and beyond.' },
  { cat: 'general', q: 'How do I start a project with you?', a: "Fill in our contact form or email us directly. We'll reply within one business day to schedule a discovery call where we scope your project and provide a fixed-price proposal." },
  { cat: 'services', q: 'Do you build mobile apps?', a: "Yes. We build cross-platform apps (React Native / Flutter) and native iOS/Android when performance demands it. We'll advise which approach fits your scope and budget." },
  { cat: 'services', q: 'Do you offer AI development?', a: "Yes, including LLM-powered features, RAG pipelines, workflow automation, and AI integrations. We're precise about scope: we'll tell you clearly what's AI integration vs. custom ML." },
  { cat: 'services', q: 'Can you take over an existing project?', a: "Yes. We begin with a code audit to assess the state of the codebase before committing to a scope. If it's salvageable, we'll work with it; if a rebuild is more cost-effective, we'll say so." },
  { cat: 'process', q: 'How long does a typical project take?', a: 'Websites: 4-8 weeks. Mobile apps: 8-16 weeks. Custom systems vary by complexity and are scoped during our discovery call. AI projects depend on feasibility assessment outcomes.' },
  { cat: 'process', q: 'What do I own at the end?', a: "Full source code, documentation, and all credentials. No vendor lock-in, no platform dependency. It's yours." },
  { cat: 'process', q: 'Will I talk to the actual engineer?', a: "Yes. We don't have account managers between you and the work. You'll interact directly with the engineer building your project." },
  { cat: 'pricing', q: 'How are projects priced?', a: "Fixed-price proposals after a scoping call. We don't do open-ended hourly billing for project work. See our Pricing page for starting points by service." },
  { cat: 'pricing', q: 'Can I pay in milestones?', a: 'Yes. Standard terms are 50% on kickoff and 50% on delivery. Larger projects use milestone schedules outlined in the proposal.' },
  { cat: 'pricing', q: 'Do you offer maintenance retainers?', a: 'Yes. Monthly Maintenance & Support retainers cover uptime monitoring, security patches, dependency updates, and a monthly content/feature update quota.' },
  { cat: 'technical', q: 'What tech stack do you use?', a: 'It depends on the project. For marketing sites: Astro + TypeScript + Tailwind. For apps: React Native or Flutter. For systems: TypeScript / Node.js / PostgreSQL. For AI: LLM APIs, RAG, Python.' },
  { cat: 'technical', q: 'Will I be able to update the site myself?', a: "Yes. If content management is a requirement, we'll include a CMS (headless or custom) so non-technical users can update content without touching code." },
  { cat: 'technical', q: 'Do you host the site?', a: "We deploy to Cloudflare Pages by default, since it's fast, global, and free on their starter tier. We can deploy to Vercel, AWS, or other platforms if you have an existing preference." },
];
---

<BaseLayout
  title="FAQs: WSS DevLabs"
  description="Answers to common questions about WSS DevLabs, covering services, process, pricing, and technical approach."
  path="/faq"
>
  <!-- Dark support hero + search -->
  <section class="relative overflow-hidden bg-charcoal py-16 md:py-20">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.05] [background-image:radial-gradient(circle,white_1px,transparent_1px)] [background-size:26px_26px]"
      aria-hidden="true"
    />
    <Container class="relative">
      <div class="mx-auto max-w-xl text-center">
        <p class="mono-label justify-center text-white/50">Support</p>
        <h1 class="h-display-xl mt-3 !text-[clamp(2rem,1.4rem+2.4vw,3.2rem)] text-white" data-split>
          Frequently Asked Questions
        </h1>
        <p class="mt-4 leading-relaxed text-white/60">
          Need help with something? Here are the questions we get asked most.
        </p>

        <div class="mt-6 flex items-center gap-2 rounded-full border border-white/15 bg-white/5 p-1.5">
          <svg class="ml-2.5 h-4 w-4 shrink-0 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="faq-search"
            type="text"
            placeholder="Search questions..."
            class="min-w-0 flex-1 bg-transparent px-1 py-2 text-sm text-white placeholder:text-white/40 focus:outline-none"
          />
        </div>
      </div>
    </Container>
  </section>

  <!-- Category sections -->
  <div id="faq-search-scope">
    {
      categories.map((cat) => {
        const items = allFaqs.filter((f) => f.cat === cat.id).map((f) => ({ question: f.q, answer: f.a }));
        return <FAQ title={cat.label} items={items} />;
      })
    }
  </div>

  <CTABand title="Still have questions?" subtitle="Our team replies within one business day." ctaLabel="Ask us directly" />
</BaseLayout>

<script>
  function initFaqSearch() {
    const input = document.getElementById('faq-search') as HTMLInputElement | null;
    const scope = document.getElementById('faq-search-scope');
    if (!input || !scope || input.dataset.bound) return;
    input.dataset.bound = '1';

    const sections = Array.from(scope.querySelectorAll<HTMLElement>(':scope > section'));

    input.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();

      sections.forEach((section) => {
        const items = Array.from(section.querySelectorAll<HTMLDetailsElement>('details'));
        let visibleCount = 0;

        items.forEach((item) => {
          const question = item.querySelector('summary')?.textContent?.toLowerCase() ?? '';
          const match = !query || question.includes(query);
          item.classList.toggle('hidden', !match);
          if (match) visibleCount += 1;
        });

        section.classList.toggle('hidden', visibleCount === 0);
      });
    });
  }

  initFaqSearch();
  document.addEventListener('astro:page-load', initFaqSearch);
</script>
