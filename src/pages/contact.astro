---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { SITE } from '../data/site';
import { SERVICES } from '../data/services';
---

<BaseLayout
  title="Contact Us: WSS DevLabs"
  description="Get in touch with WSS DevLabs. Start a project, ask a question, or request a free quote."
  path="/contact"
>

  <!-- Contact intro + form -->
  <section class="border-b border-line">
    <Container class="py-12 md:py-16">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Left: heading + info -->
        <div>
          <p class="mono-label text-ink-dim">Get in touch</p>
          <h1 class="h-display mt-3 !text-[clamp(2rem,1.3rem+2.6vw,3.2rem)]" data-split>
            We are always ready to help you and answer your questions
          </h1>
          <p class="mt-4 max-w-md leading-relaxed text-ink-dim">
            Reach out however works best for you, and someone from our team will get back to you
            within one business day.
          </p>

          <div class="mt-10 grid gap-8 sm:grid-cols-2">
            <div>
              <p class="mono-label text-ink-dim">Call Center</p>
              <p class="mt-2 text-sm font-semibold text-ink">{SITE.phone}</p>
              <p class="mt-1 text-sm font-semibold text-ink">{SITE.whatsapp} (WhatsApp)</p>
            </div>
            <div>
              <p class="mono-label text-ink-dim">Our Location</p>
              <p class="mt-2 text-sm font-semibold text-ink">{SITE.address}</p>
            </div>
            <div>
              <p class="mono-label text-ink-dim">Email</p>
              <p class="mt-2 text-sm font-semibold text-ink">{SITE.email}</p>
            </div>
            <div>
              <p class="mono-label text-ink-dim">Social Network</p>
              <div class="mt-2 flex items-center gap-2">
                {SITE.social.linkedin && (
                  <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-all hover:border-accent hover:bg-accent hover:text-white">
                    <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
                  </a>
                )}
                {SITE.social.twitter && (
                  <a href={SITE.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-all hover:border-accent hover:bg-accent hover:text-white">
                    <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
                  </a>
                )}
                {SITE.social.instagram && (
                  <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-all hover:border-accent hover:bg-accent hover:text-white">
                    <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" /></svg>
                  </a>
                )}
                {SITE.social.facebook && (
                  <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-dim transition-all hover:border-accent hover:bg-accent hover:text-white">
                    <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Right: dark quick-contact form -->
        <div class="panel-charcoal p-8 md:p-10">
          <h2 class="text-lg font-bold text-white">Get In Touch</h2>
          <p class="mt-1.5 text-sm text-white/55">Tell us what you're building and we'll reply within one business day.</p>

          <form id="contact-form" class="mt-6 space-y-4" onsubmit="return false;">
            <div>
              <label for="c-name" class="mb-1.5 block text-xs font-semibold text-white/70">Your Name</label>
              <input id="c-name" type="text" placeholder="Ex. Aiman Rasyid" required class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/35 focus:border-accent focus:outline-none" />
            </div>
            <div>
              <label for="c-email" class="mb-1.5 block text-xs font-semibold text-white/70">Email</label>
              <input id="c-email" type="email" placeholder="example@gmail.com" required class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/35 focus:border-accent focus:outline-none" />
            </div>
            <div>
              <label for="c-service" class="mb-1.5 block text-xs font-semibold text-white/70">Service Interested In</label>
              <select id="c-service" class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white focus:border-accent focus:outline-none">
                <option value="" class="text-ink">Select Service</option>
                {SERVICES.map((s) => <option value={s.slug} class="text-ink">{s.title}</option>)}
              </select>
            </div>
            <div>
              <label for="c-message" class="mb-1.5 block text-xs font-semibold text-white/70">Your Message</label>
              <textarea id="c-message" rows="4" placeholder="Enter here..." class="w-full resize-none rounded-xl border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/35 focus:border-accent focus:outline-none" />
            </div>
            <div id="c-success" class="hidden rounded-xl bg-accent-green/15 px-4 py-3 text-sm font-semibold text-accent-green">
              Message sent! We will reply within one business day.
            </div>
            <button type="submit" id="c-submit" class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-accent-red px-7 py-3 text-sm font-bold text-white shadow-md shadow-black/20 transition-colors hover:bg-accent-red-dim active:scale-95">
              Send Message
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </button>
          </form>
        </div>
      </div>
    </Container>
  </section>

  <!-- Map -->
  <div class="border-b border-line">
    <Container class="py-6">
      <div class="perspective-wrap relative overflow-hidden rounded-[2rem] border border-line" data-reveal="tilt3d">
        <div
          id="contact-map"
          role="img"
          aria-label="Map showing WSS DevLabs location in Kuala Lumpur"
          class="h-[320px] w-full bg-paper-dim md:h-[440px]"
        />

        <!-- Floating office card -->
        <div class="animate-float absolute left-5 top-5 max-w-xs md:left-8 md:top-8">
          <div class="tilt-card glass-float-card flex gap-4 p-4">
            <img
              src="https://picsum.photos/seed/wss-devlabs-hq-office/160/160"
              alt="WSS DevLabs office"
              class="h-16 w-16 shrink-0 rounded-xl object-cover"
              loading="lazy"
              width="160"
              height="160"
            />
            <div class="min-w-0">
              <p class="truncate font-semibold text-ink">{SITE.name}</p>
              <p class="mt-1 text-xs leading-relaxed text-ink-dim">{SITE.address}</p>
              <p class="mono-label mt-1.5 !text-[0.62rem] text-accent">{SITE.hours}</p>
              <a
                href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(SITE.address)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="link-underline mt-2 inline-flex items-center gap-1.5 text-xs font-semibold text-accent"
              >
                Get directions
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </div>


</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('c-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('c-name') as HTMLInputElement).value;
      const email = (document.getElementById('c-email') as HTMLInputElement).value;
      const service = (document.getElementById('c-service') as HTMLSelectElement).value;
      const message = (document.getElementById('c-message') as HTMLTextAreaElement).value;
      const subject = encodeURIComponent(`New enquiry from ${name}`);
      const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\nService: ${service}\n\nMessage:\n${message}`);
      window.location.href = `mailto:hello@wssdevlabs.com?subject=${subject}&body=${body}`;
      success.classList.remove('hidden');
      form.reset();
    });
  }
</script>

<script>
  import 'leaflet/dist/leaflet.css';
  import L from 'leaflet';

  const OFFICE: [number, number] = [3.149, 101.695];
  let map: L.Map | null = null;

  function initContactMap() {
    const el = document.getElementById('contact-map');
    if (!el || map) return;

    map = L.map(el, {
      center: OFFICE,
      zoom: 13,
      scrollWheelZoom: false,
      zoomControl: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);

    L.control.zoom({ position: 'bottomright' }).addTo(map);

    const pin = L.divIcon({
      className: '',
      html:
        '<span style="display:block;height:14px;width:14px;border-radius:9999px;background:var(--color-accent);border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,.35)"></span>',
      iconSize: [14, 14],
      iconAnchor: [7, 7]
    });

    L.marker(OFFICE, { icon: pin }).addTo(map);
  }

  function teardownContactMap() {
    map?.remove();
    map = null;
  }

  initContactMap();
  document.addEventListener('astro:page-load', initContactMap);
  document.addEventListener('astro:before-swap', teardownContactMap);
</script>
