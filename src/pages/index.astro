---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/ui/Marquee.astro';
import WhateverYouNeed from '../components/sections/WhateverYouNeed.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import HomepageServices from '../components/sections/HomepageServices.astro';
import Differentiator from '../components/sections/Differentiator.astro';
import ProcessOverview from '../components/sections/ProcessOverview.astro';
import FeaturedWork from '../components/sections/FeaturedWork.astro';
import ImpactStats from '../components/sections/ImpactStats.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTABand from '../components/sections/CTABand.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactTeaser from '../components/sections/ContactTeaser.astro';
import { HOME_FAQ } from '../data/faq';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featuredProjects = allProjects.filter((p) => p.data.featured).slice(0, 4);

const defaultTestimonials = [
  {
    quote: 'WSS DevLabs built our platform from scratch in 8 weeks. The code quality and attention to performance was well beyond what I expected from a studio this lean.',
    author: 'Ahmad Razif',
    role: 'Founder',
    company: 'Nexora Sdn Bhd',
    rating: 5,
  },
  {
    quote: 'They handled our e-commerce migration with zero downtime and delivered SEO improvements we started seeing within the first month.',
    author: 'Priya Nair',
    role: 'Head of Digital',
    company: 'RetailPlus MY',
    rating: 5,
  },
  {
    quote: 'The AI lead-qualification tool they built cut our response time by 70%. Solid engineers who actually understand product requirements.',
    author: 'Marcus Tan',
    role: 'CEO',
    company: 'GrowthStack',
    rating: 5,
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'WSS DevLabs',
  url: Astro.site?.toString(),
  description:
    'Your one-stop digital solutions partner: websites, mobile apps, custom systems, AI, marketing, branding, and more.'
};
---

<BaseLayout
  title="WSS DevLabs: Your Digital Solutions Partner"
  description="Websites, apps, systems, marketing, branding, student projects, grants, and business launches. Whatever the digital need, one team handles it."
  path="/"
  schema={schema}
>
  <Hero
    eyebrow="Every Digital Need, One Team"
    title="Whatever you need, we can build it."
    subtitle="Websites, apps, systems, marketing, branding, even student projects and grant-funded builds, one team, done properly."
    primaryCta={{ label: 'Start a Project', href: '/contact' }}
    secondaryCta={{ label: 'See our work', href: '/work' }}
  />
  <Marquee />
  <WhateverYouNeed />
  <AboutSection />
  <HomepageServices />
  <Differentiator />
  <ProcessOverview />
  <FeaturedWork projects={featuredProjects} />
  <Testimonials testimonials={defaultTestimonials} />
  <FAQ items={HOME_FAQ} />
  <ImpactStats stats={[
    { value: '50+', label: 'Projects delivered' },
    { value: '100%', label: 'Client satisfaction' },
    { value: '10', label: 'Service areas' },
    { value: '3+', label: 'Years in business' }
  ]} />
  <CTABand
    title="Have a project in mind?"
    subtitle="Tell us what you're building, and we'll respond within one business day."
  />
  <ContactTeaser />
</BaseLayout>
