---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import FAQ from '../components/sections/FAQ.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { PROCESS_PHASES } from '../data/process';

const processFaq = [
  {
    question: 'How long does a typical project take?',
    answer:
      'Most websites take 4-8 weeks; mobile apps and custom systems vary by scope, agreed during Strategize.'
  },
  {
    question: 'What do I own at the end?',
    answer: 'Full source code, documentation, and credentials, with no vendor lock-in.'
  },
  {
    question: 'What happens at handover?',
    answer:
      'You get a walkthrough of the finished build, all source code and credentials, and a sign-off checklist covering everything scoped at the start. Nothing is marked complete until you confirm it.'
  },
  {
    question: 'What documentation do I receive?',
    answer:
      'Setup and deployment notes, an overview of the system architecture, and instructions for whoever maintains or extends the project next, whether that is us or your own team.'
  },
  {
    question: 'Is there support after launch?',
    answer:
      'Yes. Every project includes a post-launch window for fixes at no extra cost, and ongoing maintenance or feature work is available afterward on a retainer or ad-hoc basis.'
  },
  {
    question: 'How do sign-offs work during the project?',
    answer:
      'Each phase, Strategize, Build, and Evolve, ends with a checkpoint where you review and approve the work before we move on, so nothing reaches handover as a surprise.'
  }
];
---

<BaseLayout
  title="Process: WSS DevLabs"
  description="How WSS DevLabs works: Strategize, Build, and Evolve, with clear scope, honest timelines, and full ownership at handover."
  path="/process"
>
  <Hero
    eyebrow="Process"
    title="Strategize. Build. Evolve."
    subtitle="Clear scope, honest timelines, and a process that doesn't end at launch."
    primaryCta={{ label: 'Start a Project', href: '/contact' }}
  />

  <!-- Phase timeline -->
  <Section rule>
    <Container>
      <div class="relative">
        <div class="absolute left-0 right-0 top-[7px] hidden h-px bg-line md:block" aria-hidden="true" />
        <div class="grid gap-12 md:grid-cols-3 md:gap-8" data-stagger>
          {
            PROCESS_PHASES.map((phase, index) => (
              <div data-stagger-child class="relative">
                <div class="relative z-10 flex items-center gap-3">
                  <span class="h-3.5 w-3.5 shrink-0 rounded-full bg-accent ring-4 ring-paper" aria-hidden="true" />
                  <span class="mono-label text-ink-dim">{String(index + 1).padStart(2, '0')}</span>
                </div>
                <h2 class="h-sub mt-6">{phase.phase}</h2>
                <p class="mt-2.5 leading-relaxed text-ink-dim">{phase.summary}</p>
                <ul class="mt-6 space-y-2.5">
                  {phase.steps.map((step) => (
                    <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink-dim">
                      <svg class="mt-[3px] h-3.5 w-3.5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      {step}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </Container>
  </Section>

  <FAQ title="Process FAQ" items={processFaq} />
</BaseLayout>
