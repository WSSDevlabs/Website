---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CTABand from '../components/sections/CTABand.astro';
import FAQ from '../components/sections/FAQ.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { PROCESS_PHASES } from '../data/process';

const processFaq = [
  {
    question: 'How long does a typical project take?',
    answer:
      'Most websites take 4–8 weeks; mobile apps and custom systems vary by scope, agreed during Strategize.'
  },
  {
    question: 'What do I own at the end?',
    answer: 'Full source code, documentation, and credentials — no vendor lock-in.'
  }
];
---

<BaseLayout
  title="Process"
  description="How WSS DevLabs works: Strategize, Build, Evolve — clear scope, honest timelines, full ownership at handover."
  path="/process"
>
  <Hero
    eyebrow="Process"
    title="Strategize. Build. Evolve."
    subtitle="Clear scope, honest timelines, and a process that doesn't end at launch."
    primaryCta={{ label: 'Start a Project', href: '/contact' }}
  />

  {
    PROCESS_PHASES.map((phase, index) => (
      <Section class={index > 0 ? 'border-t border-line' : ''}>
        <Container class="max-w-3xl">
          <p class="text-sm font-medium text-accent">Phase 0{index + 1}</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-ink">{phase.phase}</h2>
          <p class="mt-3 text-ink-dim">{phase.summary}</p>
          <ul class="mt-6 space-y-2">
            {phase.steps.map((step) => (
              <li class="text-ink-dim">— {step}</li>
            ))}
          </ul>
        </Container>
      </Section>
    ))
  }

  <Section class="border-t border-line">
    <Container class="max-w-3xl">
      <h2 class="text-2xl font-semibold tracking-tight text-ink">Timeline expectations</h2>
      <p class="mt-4 text-ink-dim">
        Timelines are scoped per project during Strategize and confirmed before Build begins — no
        open-ended engagements.
      </p>
    </Container>
  </Section>

  <Section class="border-t border-line">
    <Container class="max-w-3xl">
      <h2 class="text-2xl font-semibold tracking-tight text-ink">What you get</h2>
      <ul class="mt-6 space-y-2 text-ink-dim">
        <li>— Full ownership of source code and assets at handover</li>
        <li>— Documentation for whoever maintains the system next</li>
        <li>— A clear path into ongoing maintenance, if you want it</li>
      </ul>
    </Container>
  </Section>

  <FAQ title="Process FAQ" items={processFaq} />

  <CTABand title="Ready to start the conversation?" ctaLabel="Start a Project" ctaHref="/contact" />
</BaseLayout>
