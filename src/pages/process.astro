---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/sections/FAQ.astro';
import Container from '../components/ui/Container.astro';

const STEPS = [
  {
    n: 1,
    title: 'Discovery call',
    description:
      'A call to walk through your goals, current setup, and budget, before anything is scoped or quoted.'
  },
  {
    n: 2,
    title: 'Proposal & quote',
    description:
      'A written proposal with scope, deliverables, timeline, and a fixed price, sent for you to review with no obligation.'
  },
  {
    n: 3,
    title: 'Contract & deposit',
    description:
      'A signed agreement and deposit lock in your start date and the scope agreed in the proposal.'
  },
  {
    n: 4,
    title: 'Kickoff & requirements',
    description:
      'A detailed requirements session, plus your brand assets, content, and account access handed over so we can start.'
  },
  {
    n: 5,
    title: 'Design sign-off',
    description:
      'Wireframes first, then high-fidelity UI, reviewed and approved by you before a single line of code is written.'
  },
  {
    n: 6,
    title: 'Development sprints',
    description:
      'Staged sprints with a staging link you can follow, so you see real progress and can redirect early.'
  },
  {
    n: 7,
    title: 'QA & client review',
    description:
      'Internal testing across devices, then your own review round with revisions before anything is called finished.'
  },
  {
    n: 8,
    title: 'Sign-off, launch & handover',
    description:
      'Formal approval, deployment to production, and full source code, credentials, and documentation handed over.'
  }
];

const processFaq = [
  {
    question: 'How long does a typical project take?',
    answer:
      'Most websites take 4-8 weeks; mobile apps and custom systems vary by scope, agreed once we send a proposal and quote.'
  },
  {
    question: 'What do I own at the end?',
    answer: 'Full source code, documentation, and credentials, with no vendor lock-in.'
  },
  {
    question: 'What happens at handover?',
    answer:
      'You get a walkthrough of the finished build, all source code and credentials, and a sign-off checklist covering everything scoped at the start. Nothing is marked complete until you confirm it.'
  },
  {
    question: 'What documentation do I receive?',
    answer:
      'Setup and deployment notes, an overview of the system architecture, and instructions for whoever maintains or extends the project next, whether that is us or your own team.'
  },
  {
    question: 'Is there support after launch?',
    answer:
      'Yes. Every project includes a post-launch window for fixes at no extra cost, and ongoing maintenance or feature work is available afterward on a retainer or ad-hoc basis.'
  },
  {
    question: 'How do sign-offs work during the project?',
    answer:
      'Design and QA each end with a review checkpoint where you approve the work before we move on, so nothing reaches final sign-off as a surprise.'
  }
];
---

<BaseLayout
  title="Process: WSS DevLabs"
  description="How WSS DevLabs works, from the first discovery call through proposal, contract, development, sign-off, and post-launch support."
  path="/process"
>
  <!-- Eight-step scroll timeline: matte-dark, alternating, line fills as you scroll -->
  <section class="relative overflow-hidden bg-charcoal py-16 md:py-24">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.05] [background-image:radial-gradient(circle,white_1px,transparent_1px)] [background-size:26px_26px]"
      aria-hidden="true"
    />
    <Container class="relative">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="h-display-xl !text-[clamp(2.1rem,1.5rem+2vw,3.1rem)] text-white" data-split>
          How we get you to launch
        </h1>
        <p class="mt-4 leading-relaxed text-white/60">
          From the first call to sign-off, here is exactly what happens and when.
        </p>
      </div>

      <div class="relative mt-16" data-timeline-track>
        <!-- Base rule + scroll-scrubbed fill, desktop -->
        <div class="absolute left-1/2 top-0 hidden h-full w-px -translate-x-1/2 md:block" aria-hidden="true">
          <div class="absolute inset-0 bg-white/10" />
          <div class="absolute inset-0 bg-accent" style="transform-origin: top; transform: scaleY(0);" data-timeline-fill />
        </div>
        <!-- Mobile rule -->
        <div class="absolute left-4 top-0 h-full w-px bg-white/10 md:hidden" aria-hidden="true" />

        <div class="space-y-10 md:space-y-4">
          {
            STEPS.map((s, i) => (
              <div class="relative grid items-start gap-6 pl-12 md:grid-cols-[1fr_2.5rem_1fr] md:gap-x-8 md:pl-0">
                <span
                  class="stat-num absolute left-4 top-0 z-10 flex h-8 w-8 -translate-x-1/2 items-center justify-center rounded-full bg-accent text-xs text-white ring-4 ring-charcoal md:relative md:left-auto md:top-auto md:col-start-2 md:mx-auto md:-translate-x-0"
                >
                  {s.n}
                </span>

                {i % 2 === 0 ? (
                  <>
                    <div
                      class="rounded-3xl border border-white/10 bg-charcoal-soft p-6 md:col-start-1 md:row-start-1"
                      data-reveal="tilt3d"
                    >
                      <h2 class="text-lg font-semibold tracking-tight text-white">{s.title}</h2>
                      <p class="mt-2 text-sm leading-relaxed text-white/60">{s.description}</p>
                    </div>
                    <div class="hidden md:col-start-3 md:row-start-1 md:block" aria-hidden="true" />
                  </>
                ) : (
                  <>
                    <div class="hidden md:col-start-1 md:row-start-1 md:block" aria-hidden="true" />
                    <div
                      class="rounded-3xl border border-white/10 bg-charcoal-soft p-6 md:col-start-3 md:row-start-1"
                      data-reveal="tilt3d"
                    >
                      <h2 class="text-lg font-semibold tracking-tight text-white">{s.title}</h2>
                      <p class="mt-2 text-sm leading-relaxed text-white/60">{s.description}</p>
                    </div>
                  </>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <FAQ title="Process FAQ" items={processFaq} />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initTimelineFill() {
    const track = document.querySelector<HTMLElement>('[data-timeline-track]');
    const fill = document.querySelector<HTMLElement>('[data-timeline-fill]');
    if (!track || !fill) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    gsap.to(fill, {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: { trigger: track, start: 'top 65%', end: 'bottom 65%', scrub: true }
    });
  }

  initTimelineFill();
  document.addEventListener('astro:page-load', initTimelineFill);
</script>
