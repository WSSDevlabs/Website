---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/seo/SEO.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/layout/WhatsAppButton.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: Record<string, unknown>;
};

const { title, description, path, ogImage, type, noindex, schema } = Astro.props;
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      type={type}
      noindex={noindex}
    />
    {schema && <JsonLd schema={schema} />}
    <ClientRouter />
    {
      cfAnalyticsToken && (
        <script
          type="text/partytown"
          is:inline
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
        />
      )
    }
  </head>
  <body class="bg-paper text-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-paper"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <CookieConsent />
  </body>
</html>

<script>
  import { setupMotion } from '../scripts/siteMotion';

  // Handles initial load + every View Transition, with teardown between pages
  setupMotion();
</script>
