---
import BaseLayout from './BaseLayout.astro';

type Props = {
  title: string;
  description: string;
  path: string;
  serviceName: string;
};

const { title, description, path, serviceName } = Astro.props;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', siteUrl).toString() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: new URL('/services', siteUrl).toString()
    },
    { '@type': 'ListItem', position: 3, name: serviceName, item: new URL(path, siteUrl).toString() }
  ]
};
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <slot />
</BaseLayout>
